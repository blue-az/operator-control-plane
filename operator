def normalize_sha256(value: str) -> str:
    if not isinstance(value, str) or not VALID_SHA256.fullmatch(value):
        raise EvidenceFingerprintError("SHA-256 must be exactly 64 hexadecimal characters")
    return value.lower()


def fingerprint_regular_file(filepath: str) -> dict:
    try:
        sha256 = hashlib.sha256()
        fd = os.open(filepath, os.O_RDONLY | os.O_NONBLOCK)
        with os.fdopen(fd, "rb") as f:
            before = os.fstat(f.fileno())
            if not stat.S_ISREG(before.st_mode):
                raise EvidenceFingerprintError(f"Evidence path is not a regular file: {filepath}")
            for chunk in iter(lambda: f.read(65536), b""):
                sha256.update(chunk)
            after = os.fstat(f.fileno())
        path_after = os.stat(filepath)
    except EvidenceFingerprintError:
        raise
    except OSError as exc:
        raise EvidenceFingerprintError(
            f"Could not fingerprint evidence file '{filepath}': {exc}"
        ) from exc

    before_identity = (before.st_dev, before.st_ino, before.st_size, before.st_mtime_ns)
    after_identity = (after.st_dev, after.st_ino, after.st_size, after.st_mtime_ns)
    if before_identity != after_identity:
        raise EvidenceFingerprintError(f"Evidence file changed while fingerprinting: {filepath}")
    path_identity = (
        path_after.st_dev,
        path_after.st_ino,
        path_after.st_size,
        path_after.st_mtime_ns,
    )
    if after_identity != path_identity:
        raise EvidenceFingerprintError(f"Evidence path changed while fingerprinting: {filepath}")

    return {
        "algorithm": "sha256",
        "value": sha256.hexdigest(),
        "size_bytes": after.st_size,
        "mtime_ns": after.st_mtime_ns,
    }


def parse_stored_fingerprint(
    fingerprint: object, legacy_hash: object = None
) -> tuple[dict | None, str | None]:
    if fingerprint is None:
        if legacy_hash is None:
            return None, "has no SHA-256 fingerprint"
        try:
            value = normalize_sha256(legacy_hash)
        except EvidenceFingerprintError as exc:
            return None, str(exc)
        return {
            "algorithm": "sha256",
            "value": value,
            "size_bytes": None,
            "mtime_ns": None,
        }, None

    if not isinstance(fingerprint, dict):
        return None, "fingerprint must be a mapping"
    if fingerprint.get("algorithm") != "sha256":
        return None, "fingerprint algorithm must be sha256"
    try:
        value = normalize_sha256(fingerprint.get("value"))
    except EvidenceFingerprintError as exc:
        return None, str(exc)

    size_bytes = fingerprint.get("size_bytes")
    mtime_ns = fingerprint.get("mtime_ns")
    if size_bytes is not None and (type(size_bytes) is not int or size_bytes < 0):
        return None, "fingerprint size_bytes must be a non-negative integer or null"
    if mtime_ns is not None and (type(mtime_ns) is not int or mtime_ns < 0):
        return None, "fingerprint mtime_ns must be a non-negative integer or null"

    if legacy_hash is not None:
        try:
            normalized_legacy = normalize_sha256(legacy_hash)
        except EvidenceFingerprintError as exc:
            return None, str(exc)
        if normalized_legacy != value:
            return None, "raw hash does not match structured fingerprint"

    return {
        "algorithm": "sha256",
        "value": value,
        "size_bytes": size_bytes,
        "mtime_ns": mtime_ns,
    }, None


def calculate_file_hash(filepath: str) -> str | None:
    """Calculate the SHA-256 hash of a local regular file."""
    try:
        return fingerprint_regular_file(filepath)["value"]
    except EvidenceFingerprintError:
        return None


def evidence_freshness_diagnostics(evidence: dict, verified: bool) -> tuple[list[str], list[str]]:
    issues = []
    infos = []
    evidence_id = evidence.get("evidence_id", "unknown")
    provenance = evidence.get("provenance")
    source = evidence.get("source")
    source_kind = source.get("kind") if isinstance(source, dict) else None
    is_local = (
        provenance
        in {
            "local_file",
            "living_document",
            "structural_verification",
        }
        or source_kind == "local_file"
    )

    stored, fingerprint_error = parse_stored_fingerprint(
        evidence.get("fingerprint"), evidence.get("hash")
    )
    if not is_local:
        if fingerprint_error and (
            evidence.get("fingerprint") is not None or evidence.get("hash") is not None
        ):
            prefix = "[Error]" if verified else "[Warning]"
            message = f"{prefix} Evidence {evidence_id} has invalid remote fingerprint: {fingerprint_error}"
            (issues if verified else infos).append(message)
        infos.append(
            f"[Warning] Evidence {evidence_id} remote freshness is uncheckable without a local "
            "snapshot; verification command was not executed"
        )
        return issues, infos

    snapshot_path = evidence.get("path_or_url")
    if not isinstance(snapshot_path, str) or not snapshot_path:
        issues.append(f"[Error] Evidence {evidence_id} retained snapshot path is missing")
        return issues, infos
    if not os.path.exists(snapshot_path):
        issues.append(
            f"[Error] Evidence {evidence_id} retained snapshot is missing: {snapshot_path}"
        )
        return issues, infos
    if fingerprint_error:
        issues.append(
            f"[Error] Evidence {evidence_id} retained snapshot fingerprint is invalid: "
            f"{fingerprint_error}"
        )
        return issues, infos

    try:
        current = fingerprint_regular_file(snapshot_path)
    except EvidenceFingerprintError as exc:
        issues.append(f"[Error] Evidence {evidence_id} retained snapshot is unreadable: {exc}")
        return issues, infos

    if current["value"] != stored["value"]:
        issues.append(
            f"[Error] Evidence {evidence_id} retained snapshot content changed "
            f"(expected {stored['value']}, got {current['value']}): {snapshot_path}"
        )
        return issues, infos
    if stored["size_bytes"] is not None and current["size_bytes"] != stored["size_bytes"]:
        issues.append(
            f"[Error] Evidence {evidence_id} retained snapshot size changed "
            f"(expected {stored['size_bytes']}, got {current['size_bytes']}): {snapshot_path}"
        )
        return issues, infos
    if stored["mtime_ns"] is not None and current["mtime_ns"] != stored["mtime_ns"]:
        infos.append(
            f"[Info] Evidence {evidence_id} retained snapshot metadata changed but content "
            "fingerprint remains current"
        )

    if source_kind != "local_file":
        return issues, infos
    source_locator = source.get("locator")
    if not isinstance(source_locator, str) or not source_locator:
        issues.append(f"[Error] Evidence {evidence_id} local source locator is invalid")
        return issues, infos
    if os.path.abspath(source_locator) == os.path.abspath(snapshot_path):
        return issues, infos
    if not os.path.exists(source_locator):
        infos.append(
            f"[Warning] Evidence {evidence_id} local source is unavailable; retained snapshot "
            "remains current"
        )
        return issues, infos

    source_stored, source_error = parse_stored_fingerprint(source.get("fingerprint"))
    if source_error:
        issues.append(
            f"[Error] Evidence {evidence_id} local source fingerprint is invalid: {source_error}"
        )
        return issues, infos
    try:
        source_current = fingerprint_regular_file(source_locator)
    except EvidenceFingerprintError as exc:
        prefix = "[Error]" if verified else "[Warning]"
        message = f"{prefix} Evidence {evidence_id} local source is unreadable: {exc}"
        (issues if verified else infos).append(message)
        return issues, infos

    if source_current["value"] != source_stored["value"]:
        state = "verified" if verified else "draft"
        prefix = "[Error]" if verified else "[Warning]"
        message = (
            f"{prefix} Evidence {evidence_id} {state} local source content changed since "
            f"attachment (expected {source_stored['value']}, got {source_current['value']}): "
            f"{source_locator}"
        )
        (issues if verified else infos).append(message)
    elif (
        source_stored["mtime_ns"] is not None
        and source_current["mtime_ns"] != source_stored["mtime_ns"]
    ):
        infos.append(
            f"[Info] Evidence {evidence_id} local source metadata changed but content fingerprint "
            "remains current"
        )
    return issues, infos


def get_next_claim_id(operator_dir: str) -> str:
    """Determine the next sequential claim-XXXX ID."""
    ensure_event_store(operator_dir)
    claims_dir = os.path.join(operator_dir, "claims")
    existing = glob.glob(os.path.join(claims_dir, "claim-*.yaml"))
    max_id = max_durable_sequence(operator_dir, "claim", "claim-")
    for path in existing:
        filename = os.path.basename(path)
        match = re.match(r"claim-(\d+)\.yaml", filename)
        if match:
            num = int(match.group(1))
            if num > max_id:
                max_id = num
    return f"claim-{max_id + 1:04d}"


