        config = load_yaml(os.path.join(op_dir, "operator.yaml")) or {}
        task_id = config.get("current_task")
        if not task_id:
            print(
                "Error: No active task set. Specify task ID or create a task.",
                file=sys.stderr,
            )
            return 1

    task_path = os.path.join(op_dir, "tasks", f"{task_id}.yaml")
    if not os.path.exists(task_path):
        print(f"Error: Task '{task_id}' not found.", file=sys.stderr)
        return 1

    task = load_yaml(task_path)
    if not task:
        return 1

    handoff_id = get_next_handoff_id(op_dir, task_id)
    by = args.by if args.by else task.get("assigned_harness") or "operator"
    utc_now = get_current_utc_iso()

    handoff_data = {}
    if args.file:
        if args.file == "-":
            if sys.stdin.isatty():
                print("Paste your structured YAML handoff (press Ctrl-D to save):")
            try:
                raw = sys.stdin.read()
                handoff_data = yaml.safe_load(raw) or {}
            except Exception as e:
                print(f"Error parsing stdin YAML: {e}", file=sys.stderr)
                return 1
        else:
            if not os.path.exists(args.file):
                print(f"Error: Handoff file '{args.file}' not found.", file=sys.stderr)
                return 1
            handoff_data = load_yaml(args.file) or {}
    else:
        if (
            not (
                args.changed
                or args.verified
                or args.claimed
                or args.open
                or args.assumptions
                or args.next_action
            )
            and not sys.stdin.isatty()
        ):
            try:
                raw = sys.stdin.read()
                handoff_data = yaml.safe_load(raw) or {}
            except Exception as e:
                print(f"Error parsing piped YAML: {e}", file=sys.stderr)
                return 1
        else:
            handoff_data = {
                "what_changed": args.changed,
                "what_verified": args.verified,
                "what_claimed": args.claimed,
                "what_remains_open": args.open,
                "unchecked_assumptions": args.assumptions,
                "next_action": args.next_action,
            }

    if not isinstance(handoff_data, dict):
        print("Error: Handoff payload must be a YAML mapping/object.", file=sys.stderr)
        return 1

    handoff_fields = [
        "what_changed",
        "what_verified",
        "what_claimed",
        "what_remains_open",
        "unchecked_assumptions",
        "next_action",
    ]
    if not any(handoff_data.get(field) for field in handoff_fields):
        print(
            "Error: Handoff is empty. Provide at least one structured handoff field.",
            file=sys.stderr,
        )
        return 1

    final_data = {
        "handoff_id": handoff_id,
        "task_id": task_id,
        "by": by,
        "created_at": utc_now,
        "what_changed": handoff_data.get("what_changed"),
        "what_verified": handoff_data.get("what_verified"),
        "what_claimed": handoff_data.get("what_claimed"),
        "what_remains_open": handoff_data.get("what_remains_open"),
        "unchecked_assumptions": handoff_data.get("unchecked_assumptions"),
        "next_action": handoff_data.get("next_action"),
        "executor": get_executor_identity(),
    }

    ho_file_path = os.path.join(op_dir, "handoffs", task_id, f"{handoff_id}.yaml")
    save_yaml(final_data, ho_file_path)

    task["handoffs"] = task.get("handoffs") or []
    ref_str = f"handoffs/{task_id}/{handoff_id}.yaml"
    if ref_str not in task["handoffs"]:
        task["handoffs"].append(ref_str)

    task["updated_at"] = utc_now

    if final_data["next_action"]:
        task["next_action"] = final_data["next_action"]

    save_yaml(task, task_path)

    print(f"Successfully recorded handoff '{handoff_id}' for task '{task_id}'.")
    return 0


def session_start_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    task_id = args.task_id
    if not task_id:
        config = load_yaml(os.path.join(op_dir, "operator.yaml")) or {}
        task_id = config.get("current_task")
        if not task_id:
            print(
                "Error: No active task set. Specify task ID or create a task.",
                file=sys.stderr,
            )
            return 1

    task_path = os.path.join(op_dir, "tasks", f"{task_id}.yaml")
    if not os.path.exists(task_path):
        print(f"Error: Task '{task_id}' not found.", file=sys.stderr)
        return 1

    harness_id = args.harness_id
    harness_path = os.path.join(op_dir, "harnesses", f"{harness_id}.yaml")
    if not os.path.exists(harness_path):
        print(
            f"Error: Harness '{harness_id}' not found in harnesses/ registry.",
            file=sys.stderr,
        )
        return 1

    task = load_yaml(task_path)
    harness = load_yaml(harness_path)
    if not task or not harness:
        return 1

    if task.get("status") == "running" and not args.force:
        print(
            f"Error: Task '{task_id}' is already running. Use --force to override.",
            file=sys.stderr,
        )
        return 1

    brief_content = generate_brief_markdown(op_dir, task_id, harness_id)
    if not brief_content:
        print("Error: Brief generation failed.", file=sys.stderr)
        return 1

    harness_display_name = harness.get("display_name", harness_id)
    export_filename = f"{task_id}.{harness_id}.export.md"
    export_path = os.path.join(op_dir, "briefs", export_filename)

    export_header = (
        f"<!-- SYSTEM INSTRUCTIONS FOR {harness_display_name.upper()} -->\n"
        f"<!-- PASTE THIS ENTIRE BRIEF INTO THE CHAT SESSION TO INITIALIZE STATE -->\n"
        f"<!-- DO NOT INVENT OR ASSUME DETAILS NOT DOCUMENTED IN THIS BRIEF -->\n\n"
    )

    full_export_content = export_header + brief_content

    try:
        with open(export_path, "w") as f:
            f.write(full_export_content)
    except Exception as e:
        print(f"Error writing export brief: {e}", file=sys.stderr)
        return 1

    usage_id = get_next_usage_id(op_dir)
    utc_now = get_current_utc_iso()
    date_str = utc_now.split("T")[0]

    usage_record = {
        "usage_id": usage_id,
        "task_id": task_id,
        "harness_id": harness_id,
        "model": harness.get("model", "unknown"),
        "started_at": utc_now,
        "ended_at": None,
        "cost_estimate_usd": 0.0,
        "outcome": "unknown",
        "raw_payload": "Session started via operator session-start.",
        "executor": get_executor_identity(),
        "lane": getattr(args, "lane", None) or "unknown",
        "task_class": getattr(args, "task_class", None) or "unknown",
    }

    if getattr(args, "lane", None) is not None:
        usage_record.setdefault("field_sources", {})["lane"] = "manual"
    if getattr(args, "task_class", None) is not None:
        usage_record.setdefault("field_sources", {})["task_class"] = "manual"

    usage_file_path = os.path.join(op_dir, "usage", f"{date_str}.yaml")
    records = []
    if os.path.exists(usage_file_path):
        records = load_yaml(usage_file_path) or []
    records.append(usage_record)
    save_yaml(records, usage_file_path)

    task["status"] = "running"
    task["updated_at"] = utc_now
    save_yaml(task, task_path)

    print("=" * 80)
    print(f"SESSION INITIALIZED: {task_id} @ {harness_display_name.upper()}")
    print("=" * 80)
    print(f"1. Export brief written to: {export_path}")
    print(
        f"2. Usage placeholder recorded: {usage_id} (${usage_record['cost_estimate_usd']:.2f} USD)"
    )
    print("-" * 80)

    launch_cmd = harness.get("command")
    if launch_cmd:
        print(f"Launch command: {launch_cmd}")
    else:
        print(
            f"Launch instructions: Open your target environment for {harness_display_name}."
        )

    print("Paste instructions:")
    print(
        f"  Copy the entire content of {export_filename} and paste it into the start of your session."
    )
    print("=" * 80)

    return 0


def find_usage_record(
    op_dir: str, usage_id: str
) -> tuple[str, list, int] | tuple[None, None, None]:
    """Search all date YAML files in usage/ to find a usage_id."""
    usage_dir = os.path.join(op_dir, "usage")
    if not os.path.isdir(usage_dir):
        return None, None, None
    usage_files = glob.glob(os.path.join(usage_dir, "*.yaml"))
    for filepath in usage_files:
        records = load_yaml(filepath) or []
        for idx, rec in enumerate(records):
            if rec.get("usage_id") == usage_id:
                return filepath, records, idx
    return None, None, None


def get_open_usage_ids_for_task(op_dir: str, task_id: str) -> list[str]:
    """Return usage IDs for records on task_id that do not have ended_at set."""
    usage_dir = os.path.join(op_dir, "usage")
    if not os.path.isdir(usage_dir):
        return []

    open_ids = []
    for filepath in glob.glob(os.path.join(usage_dir, "*.yaml")):
        records = load_yaml(filepath) or []
        for rec in records:
            if rec.get("task_id") == task_id and rec.get("ended_at") is None:
                uid = rec.get("usage_id")
                if uid:
                    open_ids.append(uid)
    return open_ids


def session_end_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    usage_id = args.usage_id
    if not usage_id:
        print("Error: Specify a usage ID (e.g. usage-0001).", file=sys.stderr)
        return 1
    filepath, records, idx = find_usage_record(op_dir, usage_id)
    if not filepath:
        print(f"Error: Usage record '{usage_id}' not found.", file=sys.stderr)
        return 1

    usage_record = records[idx]

    if usage_record.get("ended_at") is not None and not args.force:
        print(
            f"Error: Usage record '{usage_id}' is already closed (ended_at: {usage_record.get('ended_at')}). Use --force to override.",
            file=sys.stderr,
        )
        return 1

    utc_now = get_current_utc_iso()
    usage_record["ended_at"] = utc_now
    usage_record["outcome"] = args.outcome
    usage_record["cost_estimate_usd"] = args.cost

    raw_payload = ""
    if not sys.stdin.isatty():
        raw_payload = sys.stdin.read().strip()
    elif args.paste:
        print("Paste your final /status or notes (press Ctrl-D to save):")
        try:
            raw_payload = sys.stdin.read().strip()
        except KeyboardInterrupt:
            print("\nAborted.")
            return 1

    if raw_payload:
        usage_record["raw_payload"] = raw_payload

    usage_record["executor"] = get_executor_identity()
    save_yaml(records, filepath)

    task_id = usage_record.get("task_id")
    if task_id:
        task_path = os.path.join(op_dir, "tasks", f"{task_id}.yaml")
        if os.path.exists(task_path):
            task = load_yaml(task_path)
            if task:
                task["updated_at"] = utc_now
                open_usage_ids = get_open_usage_ids_for_task(op_dir, task_id)
                if args.status:
                    task["status"] = args.status
                elif task.get("status") == "running" and not open_usage_ids:
                    # Task is no longer running since all sessions for it are closed.
                    # Default back to assigned if no explicit status is provided.
                    task["status"] = "assigned"
                save_yaml(task, task_path)

    print(f"Successfully closed usage session '{usage_id}'.")
    return 0


def session_list_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    usage_dir = os.path.join(op_dir, "usage")
    if not os.path.isdir(usage_dir):
        print("No sessions found in ledger.")
        return 0

    usage_files = glob.glob(os.path.join(usage_dir, "*.yaml"))

    records = []
    for filepath in usage_files:
        data = load_yaml(filepath) or []
        if isinstance(data, list):
            records.extend(data)

    if not records:
        print("No sessions found in ledger.")
        return 0

    records.sort(key=lambda r: r.get("usage_id", ""))

    filtered_records = []
    for r in records:
        if args.open and r.get("ended_at") is not None:
            continue
        if args.task_id and r.get("task_id") != args.task_id:
            continue
        if args.harness_id and r.get("harness_id") != args.harness_id:
            continue
        filtered_records.append(r)

    if not filtered_records:
        print("No sessions matched the filters.")
        return 0

    print("=" * 110)
    print(
        f"{'USAGE ID':<12} | {'TASK ID':<25} | {'HARNESS':<10} | {'STATUS':<8} | {'STARTED':<25} | {'ENDED'}"
    )
    print("=" * 110)
    for r in filtered_records:
        usage_id = r.get("usage_id", "unknown")
        task_id = r.get("task_id", "unknown")
        harness = r.get("harness_id", "unknown")
        status = "open" if r.get("ended_at") is None else "closed"
        started = r.get("started_at") or "-"
        ended = r.get("ended_at") or "-"
        print(
            f"{usage_id:<12} | {task_id:<25} | {harness:<10} | {status:<8} | {started:<25} | {ended}"
        )
    print("=" * 110)
    return 0


