def get_next_usage_id(operator_dir: str) -> str:
    """Determine the next sequential usage-XXXX ID."""
    ensure_event_store(operator_dir)
    usage_dir = os.path.join(operator_dir, "usage")
    existing = glob.glob(os.path.join(usage_dir, "*.yaml"))
    max_id = max_durable_sequence(operator_dir, "usage", "usage-")
    for path in existing:
        try:
            records = load_yaml(path) or []
            for rec in records:
                uid = rec.get("usage_id", "")
                match = re.match(r"usage-(\d+)", uid)
                if match:
                    num = int(match.group(1))
                    if num > max_id:
                        max_id = num
        except Exception:
            pass
    return f"usage-{max_id + 1:04d}"


