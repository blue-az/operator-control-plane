def anchor_record_id_to_local(record_type: str, anchor_record_id: str) -> str:
    """Reverse validate_local_ledger's wire-safe ":" encoding for evidence/handoff anchor
    record IDs back to the local "<task_id>/<leaf_id>" form used in ledger_events.record_id.
    The broker's record_id character class disallows "/", so anchors sent to (and read back
    from) the broker use ":" instead; local storage never changed and still uses "/"."""
    if record_type in {"evidence", "handoff"} and ":" in anchor_record_id:
        return anchor_record_id.replace(":", "/", 1)
    return anchor_record_id


def doctor_cmd(args) -> int:
    enrollment, op_dir = resolve_operator_context()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    if enrollment:
        ledger_id = enrollment.ledger_id
        socket_path = enrollment.socket_path
        print("=" * 80)
        print("OPERATOR DOCTOR - LEDGER CONSISTENCY REPORT")
        print("=" * 80)
        print("verification_authority: uid_isolated")
        print("policy_authority: external_broker")

        # Connect to broker and fetch snapshot using pagination
        client = None
        records = []
        broker_err = None
        broker_error_code = None
        broker_policy = None
        through_seq = None
        try:
            client = authority_client.AuthorityClient(socket_path)
            after = None
            pinned_seq = None
            while True:
                res = client.send_request(
                    {
                        "action": "projection.snapshot",
                        "ledger_id": ledger_id,
                        "through_commit_sequence": pinned_seq,
                        "after": after,
                        "limit": 16,
                    }
                )
                if res.get("ok"):
                    snapshot = res["snapshot"]
                    if pinned_seq is None:
                        pinned_seq = snapshot["through_commit_sequence"]
                        through_seq = pinned_seq
                        broker_policy = snapshot["policy"]
                    records.extend(snapshot["records"])
                    if not snapshot.get("has_more") or not snapshot.get("next_after"):
                        break
                    after = snapshot["next_after"]
                else:
                    err_obj = res.get("error")
                    if isinstance(err_obj, dict):
                        broker_error_code = err_obj.get("code")
                        broker_err = err_obj.get("message", "unknown error")
                    else:
                        broker_err = str(err_obj or "unknown error")
                    break
        except Exception as e:
            broker_err = str(e)

        if broker_err:
            if broker_error_code == "policy_revoked":
                print("status: policy_revoked")
                print(f"[Error] Broker policy has been revoked: {broker_err}")
            elif broker_error_code == "policy_rotated":
                print("status: policy_rotated")
                print(f"[Error] Broker policy has been rotated: {broker_err}")
            else:
                print("status: broker_unavailable")
                print(f"[Error] Authority broker is unreachable or returned error: {broker_err}")
            print("-" * 80)
            return 1

        if broker_policy != enrollment.policy_binding:
            print("status: policy_rotated")
            print(
                "[Error] Broker policy binding differs from the root-managed enrollment: "
                f"enrolled={canonical_json(enrollment.policy_binding)}, "
                f"broker={canonical_json(broker_policy)}"
            )
            print("-" * 80)
            return 1
        if through_seq < enrollment.first_broker_sequence:
            print("status: divergent_or_forged_local")
            print("[Error] Broker history predates the committed enrollment sequence.")
            print("-" * 80)
            return 1

        # Broker is available, check journal status read-only
        journal_path = os.path.join(op_dir, "client_journal.sqlite3")
        journal_error = None
        stored_policy = None
        if not os.path.exists(journal_path):
            last_applied = 0
            pending_count = 0
        else:
            try:
                conn_journal = sqlite3.connect(f"file:{journal_path}?mode=ro", uri=True)
                conn_journal.row_factory = sqlite3.Row
                last_applied = authority_projection.get_last_applied_sequence(conn_journal)
                pending_count = conn_journal.execute(
                    "SELECT COUNT(*) FROM transaction_journal WHERE state IN ('prepared', 'committed')"
                ).fetchone()[0]
                policy_row = conn_journal.execute(
                    "SELECT value FROM journal_metadata WHERE key = 'policy_binding'"
                ).fetchone()
                if policy_row:
                    stored_policy = json.loads(policy_row[0])
                conn_journal.close()
            except Exception as exc:
                journal_error = str(exc)

        print(
            "policy_binding: "
            f"{broker_policy['id']}@{broker_policy['generation']} {broker_policy['sha256']}"
        )
        if journal_error:
            print("status: divergent_or_forged_local")
            print(f"[Error] Client journal cannot be read safely: {journal_error}")
            print("-" * 80)
            return 1
        if stored_policy is not None and stored_policy != broker_policy:
            print("status: policy_rotated")
            print(
                "[Error] Broker policy binding differs from the last projected binding: "
                f"local={canonical_json(stored_policy)}, broker={canonical_json(broker_policy)}"
            )
            print("-" * 80)
            return 1

        effective_sequence = max(last_applied, enrollment.first_broker_sequence)
        if effective_sequence < through_seq or pending_count > 0:
            print("status: projection_pending")
            print(
                f"[Warning] Projections are pending. Local sequence: {effective_sequence}, Broker sequence: {through_seq}"
            )
            print("-" * 80)
            return 1

        # last_applied == through_seq, check for divergence/forgeries
        diverged = False
        issues = []

        # Connect to local ledger
        db_path = os.path.join(op_dir, "ledger.sqlite3")
        if not os.path.exists(db_path):
            issues.append(f"[Error] Local database {db_path} is missing.")
            diverged = True
        else:
            conn_ledger = sqlite3.connect(f"file:{db_path}?mode=ro", uri=True)
            conn_ledger.row_factory = sqlite3.Row

            # A repo enrolled before authority_projection_events existed has
            # ledger_events history but no rows in the new table yet, and
            # nothing backfills it retroactively. Report that plainly instead
            # of flagging every already-consistent record as diverged/forged.
            projection_table = conn_ledger.execute(
                "SELECT 1 FROM sqlite_master WHERE type = 'table' AND name = 'authority_projection_events'"
            ).fetchone()
            if not projection_table and records:
                print("status: projection_schema_migration_required")
                print(
                    "[Warning] This ledger predates broker-projection-version tracking "
                    "(authority_projection_events table is missing). "
                    "Divergence cannot be checked until the ledger is re-synced."
                )
                print("-" * 80)
                conn_ledger.close()
                return 1

            try:
                # Compare snapshot records to local database and YAML projections
                for record in records:
                    rtype = record["record_type"]
                    rid = record["record_id"]
                    rversion = record["version"]
                    revent_hash = record["event_hash"]
                    rpayload = record["payload"]

                    # Get local db version and hash
                    local_ver, local_hash = authority_projection.get_local_record_version(
                        conn_ledger, rtype, rid
                    )
                    if local_ver != rversion or local_hash != revent_hash:
                        issues.append(
                            f"[Error] Mismatch on {rtype} {rid}: Local version={local_ver}, hash={local_hash}; Broker version={rversion}, hash={revent_hash}"
                        )
                        diverged = True
                        continue

                    # Get local YAML payload
                    if rtype == "task":
                        filepath = os.path.join(op_dir, "tasks", f"{rid}.yaml")
                    elif rtype == "claim":
                        filepath = os.path.join(op_dir, "claims", f"{rid}.yaml")
                    elif rtype == "evidence":
                        filepath = os.path.join(
                            op_dir, "evidence", rpayload["task_id"], f"{rid}.yaml"
                        )
                    elif rtype == "handoff":
                        filepath = os.path.join(
                            op_dir, "handoffs", rpayload["task_id"], f"{rid}.yaml"
                        )
                    else:
                        filepath = os.path.join(op_dir, f"{rtype}s", f"{rid}.yaml")

                    if not os.path.exists(filepath):
                        issues.append(
                            f"[Error] YAML projection missing for {rtype} {rid}: {filepath}"
                        )
                        diverged = True
                        continue

                    with open(filepath, "r") as f:
                        try:
                            local_payload = yaml.safe_load(f)
                        except Exception as e:
                            issues.append(f"[Error] Failed to load YAML for {rtype} {rid}: {e}")
                            diverged = True
                            continue

                    expected_payload, _, _ = authority_projection.normalize_record(
                        op_dir, record, read_only=True
                    )

                    if canonical_json(local_payload) != canonical_json(expected_payload):
                        issues.append(f"[Error] YAML payload differs from broker for {rtype} {rid}")
                        diverged = True

                # Check for local events not in snapshot (forgeries or legacy records)
                local_records = conn_ledger.execute(
                    """
                    SELECT record_type, record_id, MAX(version) AS ver
                    FROM ledger_events
                    GROUP BY record_type, record_id
                    """
                ).fetchall()

                snapshot_keys = {(r["record_type"], r["record_id"]) for r in records}
                anchor_map = {
                    (
                        r["record_type"],
                        anchor_record_id_to_local(r["record_type"], r["record_id"]),
                    ): (r["version"], r["event_hash"])
                    for r in enrollment.anchor_records
                }

                for lr in local_records:
                    # Strip task_id prefix for evidence/handoff types when checking snapshot
                    snapshot_rid = lr["record_id"]
                    if lr["record_type"] in {"evidence", "handoff"} and "/" in snapshot_rid:
                        snapshot_rid = snapshot_rid.split("/", 1)[1]

                    snapshot_key = (lr["record_type"], snapshot_rid)

                    # 1. If it exists in the broker snapshot
                    if snapshot_key in snapshot_keys:
                        continue

                    # 2. If it does not exist in the broker snapshot, it MUST be a legacy record in anchor_map
                    lr_key = (lr["record_type"], lr["record_id"])
                    if lr_key in anchor_map:
                        anchor_ver, anchor_hash = anchor_map[lr_key]
                        if lr["ver"] > anchor_ver:
                            issues.append(
                                f"[Error] Local forged record found: {lr['record_type']} {lr['record_id']} "
                                f"(exceeds pre-enrollment anchor version {anchor_ver})"
                            )
                            diverged = True
                            continue

                        row_hash = conn_ledger.execute(
                            "SELECT event_hash FROM ledger_events WHERE record_type = ? AND record_id = ? AND version = ?",
                            (lr["record_type"], lr["record_id"], anchor_ver),
                        ).fetchone()
                        if not row_hash or row_hash[0] != anchor_hash:
                            issues.append(
                                f"[Error] Legacy record hash mismatch for {lr['record_type']} {lr['record_id']} "
                                f"at version {anchor_ver}"
                            )
                            diverged = True
                    else:
                        issues.append(
                            f"[Error] Local forged record found: {lr['record_type']} {lr['record_id']} "
                            f"(not present in broker snapshot or pre-enrollment anchor)"
                        )
                        diverged = True

                # Check legacy-only records YAML projections match database
                for reg in enrollment.anchor_records:
                    rtype = reg["record_type"]
                    rid = anchor_record_id_to_local(rtype, reg["record_id"])
                    if (rtype, rid) not in snapshot_keys:
                        # Legacy-only record! Check its YAML projection
                        if rtype == "task":
                            filepath = os.path.join(op_dir, "tasks", f"{rid}.yaml")
                        elif rtype == "claim":
                            filepath = os.path.join(op_dir, "claims", f"{rid}.yaml")
                        elif rtype == "evidence":
                            row = conn_ledger.execute(
                                "SELECT payload_json FROM ledger_events WHERE record_type = ? AND record_id = ? AND version = ?",
                                (rtype, rid, reg["version"]),
                            ).fetchone()
                            if row:
                                try:
                                    payload = json.loads(row[0])
                                    task_id = payload["task_id"]
                                    leaf_id = rid.split("/", 1)[-1]
                                    filepath = os.path.join(
                                        op_dir, "evidence", task_id, f"{leaf_id}.yaml"
                                    )
                                except Exception:
                                    filepath = None
                            else:
                                filepath = None
                        elif rtype == "handoff":
                            row = conn_ledger.execute(
                                "SELECT payload_json FROM ledger_events WHERE record_type = ? AND record_id = ? AND version = ?",
                                (rtype, rid, reg["version"]),
                            ).fetchone()
                            if row:
                                try:
                                    payload = json.loads(row[0])
                                    task_id = payload["task_id"]
                                    leaf_id = rid.split("/", 1)[-1]
                                    filepath = os.path.join(
                                        op_dir, "handoffs", task_id, f"{leaf_id}.yaml"
                                    )
                                except Exception:
                                    filepath = None
                            else:
                                filepath = None
                        else:
                            filepath = os.path.join(op_dir, f"{rtype}s", f"{rid}.yaml")

                        if not filepath or not os.path.exists(filepath):
                            issues.append(
                                f"[Error] YAML projection missing for legacy record {rtype} {rid}"
                            )
                            diverged = True
                            continue

                        with open(filepath, "r") as f:
                            try:
                                local_payload = yaml.safe_load(f)
                            except Exception as e:
                                issues.append(
                                    f"[Error] Failed to load YAML for legacy record {rtype} {rid}: {e}"
                                )
                                diverged = True
                                continue

                        row = conn_ledger.execute(
                            "SELECT payload_json FROM ledger_events WHERE record_type = ? AND record_id = ? AND version = ?",
                            (rtype, rid, reg["version"]),
                        ).fetchone()
                        if not row:
                            issues.append(
                                f"[Error] Legacy record {rtype} {rid} event not found in database"
                            )
                            diverged = True
                            continue

                        try:
                            db_payload = json.loads(row[0])
                        except Exception:
                            issues.append(
                                f"[Error] Invalid JSON payload in database for legacy record {rtype} {rid}"
                            )
                            diverged = True
                            continue

                        # validate_local_ledger already requires, at enrollment time, that every
                        # record's full YAML payload canonically equals its database payload with
                        # no field subsetting (authority_admin.py: "YAML projection differs from
                        # database"). Re-derive that same full comparison here rather than
                        # reconstructing a hand-picked field subset, which can drift from the
                        # real local schema (evidence/claim/task each carry more fields locally --
                        # produced_by, provenance, executor, etc. -- than any fixed subset lists).
                        expected_payload = db_payload

                        if canonical_json(local_payload) != canonical_json(expected_payload):
                            issues.append(
                                f"[Error] YAML payload differs from database for legacy record {rtype} {rid}"
                            )
                            diverged = True

                # Validate the complete projected chain without treating broker hashes as P0 hashes.
                chain_rows = conn_ledger.execute(
                    """
                    SELECT event_id, record_type, record_id, version, payload_json,
                           previous_event_hash, event_hash
                    FROM ledger_events
                    ORDER BY record_type, record_id, version
                    """
                ).fetchall()
                chain_state = {}
                for row in chain_rows:
                    key = (row["record_type"], row["record_id"])
                    previous = chain_state.get(key)
                    expected_version = previous[0] + 1 if previous else 1
                    expected_hash = previous[1] if previous else None
                    if (
                        row["version"] != expected_version
                        or row["previous_event_hash"] != expected_hash
                    ):
                        issues.append(
                            f"[Error] Local broker projection chain is broken for "
                            f"{key[0]} {key[1]} at version {row['version']}"
                        )
                        diverged = True
                    try:
                        if canonical_json(json.loads(row["payload_json"])) != row["payload_json"]:
                            raise ValueError("payload is not canonical")
                    except (TypeError, ValueError, json.JSONDecodeError):
                        issues.append(
                            f"[Error] Local broker projection payload is invalid for "
                            f"{key[0]} {key[1]} version {row['version']}"
                        )
                        diverged = True
                    if row["event_id"] != row["event_hash"]:
                        issues.append(
                            f"[Error] Local broker projection event identity is invalid for "
                            f"{key[0]} {key[1]} version {row['version']}"
                        )
                        diverged = True
                    chain_state[key] = (row["version"], row["event_hash"])

                audit_issues = audit_event_store(op_dir)
                if audit_issues:
                    issues.extend(audit_issues)
                    diverged = True

                expected_triggers = {
                    "ledger_events_no_update": "create trigger ledger_events_no_update before update on ledger_events begin select raise(abort, 'ledger_events is append-only'); end",
                    "ledger_events_no_delete": "create trigger ledger_events_no_delete before delete on ledger_events begin select raise(abort, 'ledger_events is append-only'); end",
                    "authority_projection_events_no_update": "create trigger authority_projection_events_no_update before update on authority_projection_events begin select raise(abort, 'authority_projection_events is append-only'); end",
                    "authority_projection_events_no_delete": "create trigger authority_projection_events_no_delete before delete on authority_projection_events begin select raise(abort, 'authority_projection_events is append-only'); end",
                }
                trigger_rows = conn_ledger.execute(
                    "SELECT name, sql FROM sqlite_master WHERE type = 'trigger'"
                ).fetchall()
                actual_triggers = {
                    row["name"]: " ".join(row["sql"].lower().split()) for row in trigger_rows
                }
                for name, expected_sql in expected_triggers.items():
                    if name.startswith("authority_projection") and not projection_table:
                        continue
                    if actual_triggers.get(name) != expected_sql:
                        issues.append(
                            f"[Error] Local append-only trigger {name} is missing or modified."
                        )
                        diverged = True

            except Exception as e:
                issues.append(f"[Error] Local database verification failed: {e}")
                diverged = True
            finally:
                conn_ledger.close()

        if diverged:
            print("status: divergent_or_forged_local")
            for iss in issues:
                print(iss)
            print("-" * 80)
            return 1

        print("status: current")
        print("All records consistent with broker.")
        print("-" * 80)
        return 0

    # Non-enrolled logic
    try:
        identity_policy = load_identity_policy(op_dir)
        mode = identity_policy["mode"]
    except Exception:
        mode = "advisory"

    print("=" * 80)
    print("OPERATOR DOCTOR - LEDGER CONSISTENCY REPORT")
    print("=" * 80)
    auth_val = "uid_isolated" if mode == "enforced" else "advisory"
    print(f"verification_authority: {auth_val}")
    print("policy_authority: local_policy")
    print("status: legacy_local_policy")
    print("-" * 80)

    tasks_dir = os.path.join(op_dir, "tasks")
    task_files = glob.glob(os.path.join(tasks_dir, "*.yaml"))

    issues = []
    infos = []
    issues.extend(audit_event_store(op_dir))

    try:
        identity_policy = load_identity_policy(op_dir)
    except IdentityPolicyError as exc:
        issues.append(f"[Error] Invalid identity policy: {exc}")
        identity_policy = {"mode": "invalid", "uids": {}}
    identity_map = identity_policy["uids"]
    mode = identity_policy["mode"]

    def check_executor_block(item, source_name):
        contains_test_identity = False
        seen = set()
        for field in ("executor", "author_executor", "verification_executor"):
            executor = item.get(field)
            if not isinstance(executor, dict):
                continue
            marker = id(executor)
            if marker in seen:
                continue
            seen.add(marker)
            if executor.get("test_override_active"):
                contains_test_identity = True
                issues.append(
                    f"[Error] {source_name} {field} contains write made with test-override active"
                )
            if executor.get("test_override_unauthorized"):
                contains_test_identity = True
                issues.append(
                    f"[Error] {source_name} {field} contains write with unauthorized "
                    "test-override attempt"
                )
        return contains_test_identity

    for tf in task_files:
        task = load_yaml(tf)
        if not isinstance(task, dict):
            continue

        file_task_id = os.path.splitext(os.path.basename(tf))[0]
        task_id = task.get("task_id")
        if (
            not isinstance(task_id, str)
            or not VALID_TASK_ID.fullmatch(task_id)
            or task_id != file_task_id
        ):
            issues.append(
                f"[Error] Task projection {os.path.basename(tf)} has invalid or mismatched "
                f"task_id: {task_id}"
            )
            continue
        check_executor_block(task, f"Task {task_id}")
        task_status = task.get("status")

        # Repo existence check
        repo_path = task.get("repo")
        if repo_path and not os.path.exists(repo_path):
            if task_status in ["verified", "complete"]:
                issues.append(
                    f"[Error] Task {task_id} repo path does not exist on disk: {repo_path}"
                )
            else:
                infos.append(
                    f"[Warning] Task {task_id} repo path does not exist on disk: {repo_path}"
                )

        claims_list = task.get("claims") or []
        quarantined_claims = []
        verified_claims = []
        verified_evidence_paths = set()
        for cid in claims_list:
            if not isinstance(cid, str) or not VALID_CLAIM_ID.fullmatch(cid):
                issues.append(f"[Error] Task {task_id} references invalid claim ID: {cid}")
                continue
            c_path = os.path.join(op_dir, "claims", f"{cid}.yaml")
            if not os.path.exists(c_path):
                issues.append(f"[Error] Task {task_id} references missing claim: {cid}")
                continue

            c_data = load_yaml(c_path)
            if not c_data:
                issues.append(f"[Error] Claim {cid} could not be loaded.")
                continue
            if c_data.get("claim_id") != cid:
                issues.append(
                    f"[Error] Claim projection {cid}.yaml contains mismatched claim_id: "
                    f"{c_data.get('claim_id')}"
                )
                continue

            if c_data.get("task_id") != task_id:
                issues.append(
                    f"[Error] Task {task_id} references claim {cid} owned by task "
                    f"{c_data.get('task_id')}"
                )

            claim_has_test_identity = check_executor_block(c_data, f"Claim {cid}")

            outcome = c_data.get("verification_outcome")
            verified = (outcome == "verified") or bool(c_data.get("verification_status"))

            if not c_data.get("required_gate"):
                issues.append(
                    f"[Warning] Claim {cid} ('{c_data.get('text')}') has no required_gate defined."
                )

            if c_data.get("type") == "supervision_credit" and not c_data.get("supervision_layer"):
                issues.append(
                    f"[Warning] Claim {cid} is a supervision_credit with no named layer (ambiguous credit; FR-12)."
                )

            evidence_refs = c_data.get("evidence_refs") or []
            if verified and not evidence_refs:
                issues.append(
                    f"[Error] Claim {cid} is marked verified but has no evidence references."
                )

            for ev_ref in evidence_refs:
                ev_ref_path = os.path.join(op_dir, ev_ref)
                if verified:
                    verified_evidence_paths.add(os.path.abspath(ev_ref_path))
                if not os.path.exists(ev_ref_path):
                    issues.append(
                        f"[Error] Claim {cid} evidence reference points to missing file: {ev_ref}"
                    )
                else:
                    ev_ref_data = load_yaml(ev_ref_path)
                    if ev_ref_data:
                        check_executor_block(ev_ref_data, f"Evidence file {ev_ref}")
                        if ev_ref_data.get("task_id") != task_id:
                            issues.append(
                                f"[Error] Claim {cid} references evidence owned by task "
                                f"{ev_ref_data.get('task_id')}: {ev_ref}"
                            )
                        bound_claim_id = ev_ref_data.get("claim_id")
                        if bound_claim_id and bound_claim_id != cid:
                            issues.append(
                                f"[Error] Claim {cid} references evidence bound to claim "
                                f"{bound_claim_id}: {ev_ref}"
                            )
                        provenance = ev_ref_data.get("provenance")
                        stored_fingerprint, _ = parse_stored_fingerprint(
                            ev_ref_data.get("fingerprint"), ev_ref_data.get("hash")
                        )

                        if provenance == "local_file" and not stored_fingerprint:
                            issues.append(
                                f"[Warning] Claim {cid} evidence reference has no valid fingerprint: {ev_ref}"
                            )

                        is_recheckable = provenance in [
                            "local_file",
                            "living_document",
                            "structural_verification",
                        ]
                        if not is_recheckable:
                            v_cmd = ev_ref_data.get("verification_command")
                            if not v_cmd or not stored_fingerprint:
                                if verified:
                                    issues.append(
                                        f"[Error] Claim {cid} verified on unverifiable evidence: {ev_ref} (external/url provenance must have verification_command and hash)"
                                    )
                                else:
                                    infos.append(
                                        f"[Warning] Claim {cid} draft on unverifiable evidence: {ev_ref} (external/url provenance must have verification_command and hash)"
                                    )

                        if ev_ref_data.get("evidence_type") == "test_output":
                            ev_path = ev_ref_data.get("path_or_url")
                            if ev_path and not ev_path.startswith(("http://", "https://")):
                                # Resolve relative path relative to repo_path if available
                                if repo_path and not os.path.isabs(ev_path):
                                    ev_path_resolved = os.path.join(repo_path, ev_path)
                                else:
                                    ev_path_resolved = ev_path

                                if not os.path.exists(ev_path_resolved):
                                    if verified:
                                        issues.append(
                                            f"[Error] Evidence {ev_ref} test_output file does not exist: {ev_path_resolved}"
                                        )
                                    else:
                                        infos.append(
                                            f"[Warning] Evidence {ev_ref} test_output file does not exist: {ev_path_resolved}"
                                        )

            if outcome == "quarantined":
                quarantined_claims.append(cid)
            elif verified:
                verified_claims.append(cid)

            if c_data.get("type") == "test_passes":
                req_gate = c_data.get("required_gate")
                if req_gate:
                    gate_path = req_gate
                    if repo_path and not os.path.isabs(gate_path):
                        gate_path = os.path.join(repo_path, gate_path)
                    if not os.path.exists(gate_path):
                        if verified:
                            issues.append(
                                f"[Error] Claim {cid} verified test_passes required_gate file does not exist: {req_gate}"
                            )
                        else:
                            infos.append(
                                f"[Warning] Claim {cid} draft test_passes required_gate file does not exist: {req_gate}"
                            )

                # Check for verification_command in evidence
                has_verification_cmd = False
                for ev_ref in evidence_refs:
                    ev_ref_path = os.path.join(op_dir, ev_ref)
                    if os.path.exists(ev_ref_path):
                        ev_ref_data = load_yaml(ev_ref_path)
                        if ev_ref_data and ev_ref_data.get("verification_command"):
                            has_verification_cmd = True
                            break
                if not has_verification_cmd:
                    if verified:
                        issues.append(
                            f"[Error] Claim {cid} verified test_passes has no evidence reference with a verification_command."
                        )
                    else:
                        infos.append(
                            f"[Warning] Claim {cid} draft test_passes has no evidence reference with a verification_command."
                        )

            made = c_data.get("made_by")
            vby = c_data.get("verified_by")
            review = task.get("review_harness")
            authority = c_data.get("verification_authority")
            recorded_mode = c_data.get("verification_mode")

            if verified:
                if authority != "uid_isolated" and vby == made:
                    issues.append(
                        f"[Error] claim {cid} is self-verified by '{made}' (maker cannot verify own claim)"
                    )
                if vby and review and vby != review:
                    issues.append(
                        f"[Warning] claim {cid} verified by '{vby}', not the task's review harness '{review}'"
                    )

            if authority == "uid_isolated":
                authority_errors = []
                author_executor = c_data.get("author_executor")
                verification_executor = c_data.get("verification_executor")
                compatibility_executor = c_data.get("executor")
                author_uid = (
                    author_executor.get("uid") if isinstance(author_executor, dict) else None
                )
                verifier_uid = (
                    verification_executor.get("uid")
                    if isinstance(verification_executor, dict)
                    else None
                )
                compatibility_uid = (
                    compatibility_executor.get("uid")
                    if isinstance(compatibility_executor, dict)
                    else None
                )

                if recorded_mode != "enforced":
                    authority_errors.append(
                        f"uid_isolated verification was not recorded in enforced mode "
                        f"(found {recorded_mode!r})"
                    )
                if mode == "single_user":
                    infos.append(
                        f"[Warning] Claim {cid} was recorded as uid_isolated, but the "
                        "current identity policy is single_user; policy immutability is "
                        "outside P2"
                    )
                if (
                    not isinstance(author_uid, int)
                    or isinstance(author_uid, bool)
                    or author_uid < 0
                ):
                    authority_errors.append("uid_isolated verification has no valid author UID")
                if (
                    not isinstance(verifier_uid, int)
                    or isinstance(verifier_uid, bool)
                    or verifier_uid < 0
                ):
                    authority_errors.append("uid_isolated verification has no valid verifier UID")
                if (
                    not isinstance(compatibility_uid, int)
                    or isinstance(compatibility_uid, bool)
                    or compatibility_uid < 0
                ):
                    authority_errors.append(
                        "uid_isolated verification has no valid compatibility executor UID"
                    )
                elif (
                    isinstance(verifier_uid, int)
                    and not isinstance(verifier_uid, bool)
                    and verifier_uid >= 0
                    and compatibility_uid != verifier_uid
                ):
                    authority_errors.append(
                        f"uid_isolated compatibility executor UID {compatibility_uid} disagrees "
                        f"with verifier UID {verifier_uid}"
                    )
                if (
                    isinstance(author_uid, int)
                    and not isinstance(author_uid, bool)
                    and author_uid >= 0
                    and isinstance(verifier_uid, int)
                    and not isinstance(verifier_uid, bool)
                    and verifier_uid >= 0
                    and author_uid == verifier_uid
                ):
                    authority_errors.append(
                        f"uid_isolated verification uses the same author and verifier UID "
                        f"({author_uid})"
                    )

                verifier_identity = (
                    identity_map.get(verifier_uid)
                    if isinstance(verifier_uid, int)
                    and not isinstance(verifier_uid, bool)
                    and verifier_uid >= 0
                    else None
                )
                if verifier_uid is not None and verifier_identity is None:
                    authority_errors.append(
                        f"uid_isolated verification uses unregistered verifier UID {verifier_uid}"
                    )
                elif verifier_identity and "verifier" not in verifier_identity["roles"]:
                    authority_errors.append(
                        f"uid_isolated verification UID {verifier_uid} lacks the verifier role"
                    )
                elif verifier_identity and vby != verifier_identity["name"]:
                    authority_errors.append(
                        f"uid_isolated verification identity mismatch: verified_by is "
                        f"'{vby}', but verifier UID {verifier_uid} maps to "
                        f"'{verifier_identity['name']}'"
                    )

                if not vby:
                    authority_errors.append("uid_isolated verification has no verified_by identity")
                if claim_has_test_identity:
                    authority_errors.append(
                        "uid_isolated verification contains a guarded test identity and is not "
                        "proof of real UID isolation"
                    )

                if authority_errors:
                    issues.extend(f"[Error] Claim {cid} {message}" for message in authority_errors)
                else:
                    infos.append(
                        f"[Info] Claim {cid} verification is uid_isolated "
                        f"(author uid {author_uid}, verifier uid {verifier_uid})"
                    )
            elif authority == "advisory":
                if recorded_mode != "single_user":
                    issues.append(
                        f"[Error] Claim {cid} advisory verification has invalid recorded mode "
                        f"{recorded_mode!r}; expected 'single_user'"
                    )
                infos.append(
                    f"[Warning] claim {cid} verification is advisory and NOT "
                    "identity-enforced (single-user mode); see EXECUTOR_IDENTITY_SPEC.md"
                )

                verification_executor = c_data.get("verification_executor")
                exec_uid = (
                    verification_executor.get("uid")
                    if isinstance(verification_executor, dict)
                    else None
                )
                expected_verifier = identity_map.get(exec_uid)
                if expected_verifier and vby != expected_verifier["name"]:
                    infos.append(
                        f"[Warning] claim {cid} would be REJECTED under enforced mode: "
                        f"verified_by '{vby}' != identity '{expected_verifier['name']}' for "
                        f"uid {exec_uid}; enforcement appears relaxed to single_user"
                    )
            elif authority is None and verified:
                infos.append(
                    f"[Info] Claim {cid} has legacy/advisory verification authority; "
                    "it is not uid_isolated"
                )
                executor = c_data.get("executor")
                if not vby or not isinstance(executor, dict):
                    infos.append(f"[Info] Claim {cid} has unknown verifier (legacy claim)")
                else:
                    exec_uid = executor.get("uid")
                    expected_verifier = identity_map.get(exec_uid)
                    if mode == "enforced":
                        if not expected_verifier:
                            infos.append(
                                f"[Warning] legacy claim {cid} verifier UID {exec_uid} is not "
                                "registered; verification remains advisory"
                            )
                        elif vby != expected_verifier["name"]:
                            infos.append(
                                f"[Warning] legacy claim {cid} verification identity mismatch: "
                                f"verified_by is '{vby}', but executor maps to "
                                f"'{expected_verifier['name']}' (uid {exec_uid}); verification "
                                "remains advisory"
                            )
                    else:
                        infos.append(
                            f"[Warning] claim {cid} verification is NOT identity-enforced "
                            "(single-user mode); see EXECUTOR_IDENTITY_SPEC.md"
                        )
                        if expected_verifier and vby != expected_verifier["name"]:
                            infos.append(
                                f"[Warning] claim {cid} would be REJECTED under enforced mode: "
                                f"verified_by '{vby}' != identity '{expected_verifier['name']}' "
                                f"for uid {exec_uid}; enforcement appears relaxed to single_user"
                            )
            elif authority is None and recorded_mode is not None:
                issues.append(
                    f"[Error] Claim {cid} has verification_mode {recorded_mode!r} but no "
                    "verification_authority"
                )
            elif authority is not None:
                issues.append(
                    f"[Error] Claim {cid} has unknown verification_authority {authority!r}"
                )

        if task_status in ["verified", "complete"] and quarantined_claims:
            issues.append(
                f"[Error] Task {task_id} status is '{task_status}' while claims are quarantined: {', '.join(quarantined_claims)}"
            )

        if task_status == "quarantined" and verified_claims:
            issues.append(
                f"[Error] Task {task_id} is quarantined while claims are still marked verified: {', '.join(verified_claims)}"
            )

        ho_list = task.get("handoffs") or []
        for ho_ref in ho_list:
            ho_path = os.path.join(op_dir, ho_ref)
            if not os.path.exists(ho_path):
                issues.append(
                    f"[Error] Task {task_id} handoff reference points to missing file: {ho_ref}"
                )
            else:
                ho_data = load_yaml(ho_path)
                if ho_data:
                    ho_id = ho_data.get("handoff_id")
                    check_executor_block(ho_data, f"Handoff {ho_id} for task {task_id}")

        if ho_list:
            latest_ho_ref = ho_list[-1]
            latest_ho_path = os.path.join(op_dir, latest_ho_ref)
            if os.path.exists(latest_ho_path):
                latest_ho = load_yaml(latest_ho_path)
                if latest_ho:
                    ho_next = latest_ho.get("next_action")
                    task_next = task.get("next_action")
                    if (
                        task_status not in ["verified", "complete"]
                        and ho_next
                        and ho_next != task_next
                    ):
                        issues.append(
                            f"[Warning] Task {task_id} next_action differs from the latest handoff recommended next action. Task: '{task_next}', Handoff: '{ho_next}'"
                        )

        ev_dir = os.path.join(op_dir, "evidence", task_id)
        if os.path.isdir(ev_dir):
            ev_files = glob.glob(os.path.join(ev_dir, "evidence-*.yaml"))
            for ef in ev_files:
                ev_data = load_yaml(ef)
                if not ev_data:
                    continue
                ev_id = ev_data.get("evidence_id")
                check_executor_block(ev_data, f"Evidence {ev_id} for task {task_id}")
                evidence_is_verified = (
                    os.path.abspath(ef) in verified_evidence_paths
                    or ev_data.get("claim_id") in verified_claims
                )
                freshness_issues, freshness_infos = evidence_freshness_diagnostics(
                    ev_data, evidence_is_verified
                )
                issues.extend(freshness_issues)
                infos.extend(freshness_infos)

        if args.audit and task_status == "verified":
            # Check for independent supervisor_verdict.md (Phase 3.2)
            # Assumption: run directories are under docs/domain_runs/DBB-001a/
            # We'll try to find a directory matching task_id (or similar)
            pass

    usage_by_task = {}
    pricing_table = load_pricing_table(op_dir)

    def check_divergence(val_manual, val_auto):
        try:
            m = float(val_manual)
            a = float(val_auto)
            if m == a:
                return False
            if a == 0 or m == 0:
                return True
            return m > 2 * a or a > 2 * m
        except Exception:
            return False

    usage_dir = os.path.join(op_dir, "usage")
    if os.path.isdir(usage_dir):
        for usage_path in glob.glob(os.path.join(usage_dir, "*.yaml")):
            records = load_yaml(usage_path) or []
            for rec in records:
                task_id = rec.get("task_id")
                usage_id = rec.get("usage_id", "unknown")
                check_executor_block(rec, f"Usage record {usage_id}")
                if task_id and rec.get("ended_at") is None:
                    usage_by_task.setdefault(task_id, []).append(usage_id)
                    infos.append(f"[Info] Task {task_id} has open usage session: {usage_id}")

                if rec.get("lane") == "frontier_driver" and rec.get("task_class") == "bounded":
                    infos.append(
                        f"[Info] Session {usage_id} is an offload candidate (tagged frontier_driver + bounded)."
                    )

                harness_id = rec.get("harness_id")
                metering = rec.get("metering")
                if not metering:
                    metering = "activity" if harness_id == "gemini-agy" else "tokens"

                if metering == "tokens" and rec.get("cost_estimate_usd") is None:
                    model = rec.get("model")
                    if model not in pricing_table:
                        issues.append(f"[Warning] price table missing model {model}")

                source_ref = rec.get("source_session_ref")
                if source_ref and not os.path.exists(source_ref):
                    issues.append(
                        f"[Warning] Usage record {usage_id} source session log file is missing: {source_ref}"
                    )

                cost_estimate = rec.get("cost_estimate_usd")
                field_sources = rec.get("field_sources", {})
                if metering == "activity" and cost_estimate is not None:
                    if field_sources.get("cost_estimate_usd") == "auto":
                        issues.append(
                            f"[Error] Usage record {usage_id} is activity-metered but has auto-calculated cost."
                        )

                auto_vals = rec.get("auto_values", {})

                for field in [
                    "tokens_in",
                    "tokens_out",
                    "tokens_cache_read",
                    "tokens_cache_write",
                    "cost_estimate_usd",
                ]:
                    if field_sources.get(field) == "manual" and field in auto_vals:
                        m_val = rec.get(field)
                        a_val = auto_vals[field]
                        if m_val is not None and a_val is not None:
                            if check_divergence(m_val, a_val):
                                issues.append(f"[Warning] manual/auto divergence on {field}")

                activity = rec.get("activity", {})
                for field in ["tool_calls", "turns", "wall_clock_s", "quota_events"]:
                    if field_sources.get(field) == "manual" and field in auto_vals:
                        m_val = activity.get(field)
                        a_val = auto_vals[field]
                        if m_val is not None and a_val is not None:
                            if check_divergence(m_val, a_val):
                                issues.append(f"[Warning] manual/auto divergence on {field}")
    infos.sort()

    for tf in task_files:
        task = load_yaml(tf)
        if not task:
            continue
        task_id = task.get("task_id", os.path.splitext(os.path.basename(tf))[0])
        status = task.get("status")
        open_usage_ids = usage_by_task.get(task_id, [])
        if status == "running" and not open_usage_ids:
            issues.append(f"[Warning] Task {task_id} is running but has no open usage session.")
        if status != "running" and open_usage_ids:
            issues.append(
                f"[Error] Task {task_id} is '{status}' but has open usage sessions: {', '.join(open_usage_ids)}"
            )
        if len(open_usage_ids) > 1:
            issues.append(
                f"[Warning] Task {task_id} has multiple open usage sessions: {', '.join(open_usage_ids)}"
            )

    print("=" * 80)
    print("OPERATOR DOCTOR - LEDGER CONSISTENCY REPORT")
    print("=" * 80)
    all_msgs = infos + issues
    if all_msgs:
        for msg in all_msgs:
            print(msg)
        print("-" * 80)

    if issues:
        print(f"Total consistency issues found: {len(issues)}")
        return 1
    else:
        has_warnings = any("Warning" in msg for msg in infos)
        if has_warnings:
            print("Records consistent, but non-fatal warnings exist. Review audit report above.")
        else:
            print("All records consistent. No issues found.")
        print("=" * 80)
        return 0


def verify_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print("Error: No .operator directory found.", file=sys.stderr)
        return 1

    run_dir = Path(args.run_dir).resolve()
    if not run_dir.is_dir():
        print(f"Error: {run_dir} is not a directory.", file=sys.stderr)
        return 1

    verdict_path = run_dir / "candidate_verdict.md"
    if not verdict_path.exists():
        print(f"Error: candidate_verdict.md missing in {run_dir}", file=sys.stderr)
        return 1

    print(f"Verifying run directory: {run_dir}")

    issues = []

    # Load candidate verdict
    try:
        with open(verdict_path, "r") as f:
            content = f.read()
            # Simple YAML extraction from markdown
            match = re.search(r"```yaml\n(.*?)\n```", content, re.DOTALL)
            if match:
                verdict_data = yaml.safe_load(match.group(1))
            else:
                # Try parsing raw if no code block
                verdict_data = yaml.safe_load(content)
    except Exception as e:
        print(f"Error parsing candidate_verdict.md: {e}", file=sys.stderr)
        return 1

    if not verdict_data:
        print("Error: Empty or invalid candidate_verdict.md", file=sys.stderr)
        return 1

    # Normalize structure (candidate_verdict might be nested or flat)
    v_info = verdict_data.get("candidate_verdict", verdict_data)

    # 1. Recalculate artifact hashes (Phase 3.1.1)
    stored_hashes = v_info.get("distinct_tools_hashes", {})
    if stored_hashes:
        for variation, stored_hash in stored_hashes.items():
            tools_path = run_dir / "saved_implementation" / "variations" / variation / "tools.py"
            if tools_path.exists():
                curr_hash = hashlib.md5(tools_path.read_bytes()).hexdigest()
                if curr_hash != stored_hash:
                    issues.append(
                        f"[Error] Hash mismatch for {variation}: stored {stored_hash}, recalculated {curr_hash}"
                    )
            else:
                issues.append(
                    f"[Warning] Referenced variation {variation} missing on disk at {tools_path}"
                )

    # 2. Verify verified_by != made_by (Phase 3.1.2)
    handoff_id = v_info.get("handoff_id")
    if handoff_id:
        # We need to find the claim in the operator ledger
        # This is a bit complex as we need to scan tasks
        found_claim = False
        tasks_dir = os.path.join(op_dir, "tasks")
        for tf in glob.glob(os.path.join(tasks_dir, "*.yaml")):
            task = load_yaml(tf)
            if not task:
                continue
            for cid in task.get("claims", []):
                if not isinstance(cid, str) or not VALID_CLAIM_ID.fullmatch(cid):
                    issues.append(f"[Error] Task references invalid claim ID: {cid}")
                    continue
                c_path = os.path.join(op_dir, "claims", f"{cid}.yaml")
                if os.path.exists(c_path):
                    c_data = load_yaml(c_path)
                    if c_data and c_data.get("text") and handoff_id in c_data.get("text", ""):
                        found_claim = True
                        made = c_data.get("made_by")
                        vby = c_data.get("verified_by")
                        if vby and made and vby == made:
                            issues.append(
                                f"[Error] Claim for {handoff_id} is self-verified by '{made}'"
                            )
        if not found_claim:
            # We skip if handoff isn't in ledger yet, but warn
            pass

    # 3. Check for Evidence Drift (Phase 3.1.3)
    # Check AGENT_HANDOFF_STATUS.md against current disk state
    status_path = Path(op_dir).parent / "AGENT_HANDOFF_STATUS.md"
    if status_path.exists():
        status_content = status_path.read_text()
        # Look for the row matching implementation_path
        impl_path = v_info.get("implementation_path")
        if impl_path:
            # Look for | Implementation Path | ... | hash | ...
            # Regex for table row
            pattern = rf"\|\s*{re.escape(impl_path)}.*\|\s*([a-f0-9]+)\s*\|"
            match = re.search(pattern, status_content, re.IGNORECASE)
            if match:
                status_hash = match.group(1)
                # Check against variation_1/tools.py hash (typical for DBB-001a)
                t1_path = (
                    run_dir / "saved_implementation" / "variations" / "variation_1" / "tools.py"
                )
                if t1_path.exists():
                    curr_t1_hash = hashlib.md5(t1_path.read_bytes()).hexdigest()[:8]
                    if curr_t1_hash != status_hash:
                        issues.append(
                            f"[Error] Evidence Drift: AGENT_HANDOFF_STATUS.md reports {status_hash}, but disk implementation hash is {curr_t1_hash}"
                        )

    if issues:
        print("--- VERIFICATION ISSUES FOUND ---")
        for msg in issues:
            print(msg)
        return 1
    else:
        print("All artifact hashes and metadata verified successfully.")
        return 0


def task_list_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    tasks_dir = os.path.join(op_dir, "tasks")
    task_files = glob.glob(os.path.join(tasks_dir, "*.yaml"))

    if not task_files:
        print("No tasks found in ledger.")
        return 0

    tasks_data = []
    for tf in sorted(task_files):
        task = load_yaml(tf)
        if not task:
            continue

        task_id = task.get("task_id")
        status = task.get("status")
        assign = task.get("assigned_harness") or "None"
        review = task.get("review_harness") or "None"
        next_act = task.get("next_action") or "None"

        claims_list = task.get("claims") or []
        verified_cnt = 0
        quarantined_cnt = 0
        open_cnt = 0

        for cid in claims_list:
            if not isinstance(cid, str) or not VALID_CLAIM_ID.fullmatch(cid):
                open_cnt += 1
                continue
            c_path = os.path.join(op_dir, "claims", f"{cid}.yaml")
            if os.path.exists(c_path):
                c_data = load_yaml(c_path)
                if c_data:
                    outcome = c_data.get("verification_outcome")
                    if outcome == "quarantined":
                        quarantined_cnt += 1
                    elif c_data.get("verification_status") or outcome == "verified":
                        verified_cnt += 1
                    else:
                        open_cnt += 1
            else:
                open_cnt += 1

        claims_summary = f"V:{verified_cnt} Q:{quarantined_cnt} O:{open_cnt}"

        tasks_data.append(
            {
                "task_id": task_id,
                "status": status,
                "assign": assign,
                "review": review,
                "claims": claims_summary,
                "next_action": next_act,
            }
        )

    print("=" * 100)
    print(
        f"{'TASK ID':<25} | {'STATUS':<12} | {'ASSIGNED':<10} | {'REVIEWER':<10} | {'CLAIMS':<10} | {'LATEST NEXT ACTION'}"
    )
    print("=" * 100)
    for td in tasks_data:
        na = td["next_action"]
        if len(na) > 30:
            na = na[:27] + "..."
        print(
            f"{td['task_id']:<25} | {td['status']:<12} | {td['assign']:<10} | {td['review']:<10} | {td['claims']:<10} | {na}"
        )
    print("=" * 100)
    return 0


