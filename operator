def find_operator_dir(start_dir: str | None = None) -> str | None:
    """Search upwards from start_dir for a directory named '.operator'."""
    if start_dir is None:
        start_dir = os.getcwd()

    current = os.path.abspath(start_dir)
    while True:
        candidate = os.path.join(current, ".operator")
        if os.path.isdir(candidate):
            return candidate
        parent = os.path.dirname(current)
        if parent == current:
            break
        current = parent
    return None


def get_current_utc_iso() -> str:
    """Return the current time in UTC ISO format."""
    return (
        datetime.datetime.now(datetime.timezone.utc).replace(microsecond=0).isoformat()
    )


def load_yaml(filepath: str) -> any:
    """Helper to load a YAML file safely."""
    try:
        with open(filepath, "r") as f:
            return yaml.safe_load(f)
    except Exception as e:
        print(f"Error loading YAML {filepath}: {e}", file=sys.stderr)
        return None


def save_yaml(data: any, filepath: str) -> bool:
    """Helper to save a python object to a YAML file."""
    try:
        os.makedirs(os.path.dirname(filepath), exist_ok=True)
        with open(filepath, "w") as f:
            yaml.safe_dump(data, f, default_flow_style=False, sort_keys=False)
        return True
    except Exception as e:
        print(f"Error saving YAML {filepath}: {e}", file=sys.stderr)
        return False


def get_executor_identity() -> dict:
    test_uid_env = os.environ.get("OPERATOR_TEST_UID")
    test_sentinel_env = os.environ.get("OPERATOR_TEST_SENTINEL")

    use_override = False
    spoof_attempt = False

    if test_uid_env:
        if test_sentinel_env == "true" or test_sentinel_env == "1":
            use_override = True
        else:
            spoof_attempt = True

    if use_override:
        uid = int(test_uid_env)
        try:
            user = pwd.getpwuid(uid).pw_name
        except Exception:
            user = f"uid-{uid}"
        return {"uid": uid, "user": user, "test_override_active": True}
    else:
        uid = os.getuid()
        try:
            user = pwd.getpwuid(uid).pw_name
        except Exception:
            user = f"uid-{uid}"
        res = {"uid": uid, "user": user}
        if spoof_attempt:
            res["test_override_unauthorized"] = True
        return res


def slugify(text: str) -> str:
    """Slugify text to generate safe task IDs."""
    text = text.lower()
    text = re.sub(r"[^a-z0-9\-_]+", "-", text)
    text = re.sub(r"-+", "-", text).strip("-")
    return text


def calculate_file_hash(filepath: str) -> str | None:
    """Calculate the SHA-256 hash of a local file."""
    sha256 = hashlib.sha256()
    try:
        with open(filepath, "rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                sha256.update(chunk)
        return sha256.hexdigest()
    except Exception:
        return None


def get_next_claim_id(operator_dir: str) -> str:
    """Determine the next sequential claim-XXXX ID."""
    claims_dir = os.path.join(operator_dir, "claims")
    existing = glob.glob(os.path.join(claims_dir, "claim-*.yaml"))
    max_id = 0
    for path in existing:
        filename = os.path.basename(path)
        match = re.match(r"claim-(\d+)\.yaml", filename)
        if match:
            num = int(match.group(1))
            if num > max_id:
                max_id = num
    return f"claim-{max_id + 1:04d}"


def get_next_evidence_id(operator_dir: str, task_id: str) -> str:
    """Determine the next sequential evidence-XXXX ID for a specific task."""
    task_ev_dir = os.path.join(operator_dir, "evidence", task_id)
    os.makedirs(task_ev_dir, exist_ok=True)
    existing = glob.glob(os.path.join(task_ev_dir, "evidence-*.yaml"))
    max_id = 0
    for path in existing:
        filename = os.path.basename(path)
        match = re.match(r"evidence-(\d+)\.yaml", filename)
        if match:
            num = int(match.group(1))
            if num > max_id:
                max_id = num
    return f"evidence-{max_id + 1:04d}"


def get_next_usage_id(operator_dir: str) -> str:
    """Determine the next sequential usage-XXXX ID."""
    usage_dir = os.path.join(operator_dir, "usage")
    existing = glob.glob(os.path.join(usage_dir, "*.yaml"))
    max_id = 0
    for path in existing:
        try:
            records = load_yaml(path) or []
            for rec in records:
                uid = rec.get("usage_id", "")
                match = re.match(r"usage-(\d+)", uid)
                if match:
                    num = int(match.group(1))
                    if num > max_id:
                        max_id = num
        except Exception:
            pass
    return f"usage-{max_id + 1:04d}"


def get_next_handoff_id(operator_dir: str, task_id: str) -> str:
    """Determine the next sequential handoff-XXXX ID for a specific task."""
    task_ho_dir = os.path.join(operator_dir, "handoffs", task_id)
    os.makedirs(task_ho_dir, exist_ok=True)
    existing = glob.glob(os.path.join(task_ho_dir, "handoff-*.yaml"))
    max_id = 0
    for path in existing:
        filename = os.path.basename(path)
        match = re.match(r"handoff-(\d+)\.yaml", filename)
        if match:
            num = int(match.group(1))
            if num > max_id:
                max_id = num
    return f"handoff-{max_id + 1:04d}"


