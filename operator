                print(
                    f"  Wall Clock: {data['wall_clock_s']}s (harness-internal; not cross-comparable)"
                )
                outs = ", ".join(
                    f"{k}:{v}" for k, v in sorted(data["outcomes"].items())
                )
                print(f"  Outcomes:   {outs}")
                print("-" * 40)
            print("=" * 80)

        if args.by_model:
            print("\n" + "=" * 80)
            print(f"SUMMARY BY MODEL ({title})")
            print("=" * 80)
            for mid, data in sorted(model_groups.items()):
                print(f"Model ID:     {mid}")
                print(f"  Runs:       {data['runs']}")
                if show_cost:
                    print(f"  Est. Cost:  ${data['cost']:.4f} USD")
                print(f"  Tool Calls: {data['tool_calls']}")
                outs = ", ".join(
                    f"{k}:{v}" for k, v in sorted(data["outcomes"].items())
                )
                print(f"  Outcomes:   {outs}")
                print("-" * 40)
            print("=" * 80)

        if getattr(args, "by_lane", False):
            print("\n" + "=" * 80)
            print(f"SUMMARY BY LANE × TASK_CLASS ({title})")
            print("=" * 80)
            lane_groups = {}
            for r in recs:
                ln = r.get("lane") or "unknown"
                tc = r.get("task_class") or "unknown"
                cost = (
                    float(r.get("cost_estimate_usd") or 0.0)
                    if r.get("cost_estimate_usd") is not None
                    else 0.0
                )
                t_in = (
                    int(r.get("tokens_in") or 0)
                    if r.get("tokens_in") is not None
                    else 0
                )
                t_out = (
                    int(r.get("tokens_out") or 0)
                    if r.get("tokens_out") is not None
                    else 0
                )

                key = (ln, tc)
                if key not in lane_groups:
                    lane_groups[key] = {
                        "cost": 0.0,
                        "runs": 0,
                        "tokens_in": 0,
                        "tokens_out": 0,
                    }
                lane_groups[key]["cost"] += cost
                lane_groups[key]["runs"] += 1
                lane_groups[key]["tokens_in"] += t_in
                lane_groups[key]["tokens_out"] += t_out

            for (ln, tc), data in sorted(lane_groups.items(), key=lambda item: item[0]):
                print(f"Lane:         {ln}")
                print(f"Task Class:   {tc}")
                print(f"  Runs:       {data['runs']}")
                if show_cost:
                    print(f"  Est. Cost:  ${data['cost']:.4f} USD")
                print(f"  Tokens In:  {data['tokens_in']}")
                print(f"  Tokens Out: {data['tokens_out']}")
                print("-" * 40)

            avoidable_cost = 0.0
            for (ln, tc), data in lane_groups.items():
                if ln.startswith("frontier_") and tc == "bounded":
                    avoidable_cost += data["cost"]
            if show_cost:
                print(f"Avoidable Rollup Cost: ${avoidable_cost:.4f} USD")
            print("=" * 80)

    if args.metering:
        tokens_recs = []
        activity_recs = []
        for r in records:
            m = r.get("metering")
            if not m:
                m = "activity" if r.get("harness_id") == "gemini-agy" else "tokens"
            if m == "tokens":
                tokens_recs.append(r)
            else:
                activity_recs.append(r)

        if tokens_recs:
            print_records_summary(
                tokens_recs, "OPERATOR USAGE & COST SUMMARY (TOKENS-METERED)", True
            )
            if activity_recs:
                print()
        if activity_recs:
            print_records_summary(
                activity_recs,
                "OPERATOR USAGE & ACTIVITY SUMMARY (ACTIVITY-METERED)",
                False,
            )
    else:
        print_records_summary(records, "OPERATOR USAGE & COST SUMMARY", True)

    return 0


