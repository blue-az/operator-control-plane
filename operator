def find_usage_record(
    op_dir: str, usage_id: str
) -> tuple[str, list, int] | tuple[None, None, None]:
    """Search all date YAML files in usage/ to find a usage_id."""
    usage_dir = os.path.join(op_dir, "usage")
    if not os.path.isdir(usage_dir):
        return None, None, None
    usage_files = glob.glob(os.path.join(usage_dir, "*.yaml"))
    for filepath in usage_files:
        records = load_yaml(filepath) or []
        for idx, rec in enumerate(records):
            if rec.get("usage_id") == usage_id:
                return filepath, records, idx
    return None, None, None


def get_open_usage_ids_for_task(op_dir: str, task_id: str) -> list[str]:
    """Return usage IDs for records on task_id that do not have ended_at set."""
    usage_dir = os.path.join(op_dir, "usage")
    if not os.path.isdir(usage_dir):
        return []

    open_ids = []
    for filepath in glob.glob(os.path.join(usage_dir, "*.yaml")):
        records = load_yaml(filepath) or []
        for rec in records:
            if rec.get("task_id") == task_id and rec.get("ended_at") is None:
                uid = rec.get("usage_id")
                if uid:
                    open_ids.append(uid)
    return open_ids


def session_end_cmd(args) -> int:
    enrollment, op_dir = resolve_operator_context()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    if enrollment:
        if args.status in ("verified", "complete"):
            print(
                "Error: Task status transitions to 'verified' or 'complete' are restricted "
                "under P3 authority. Use 'operator task-transition' instead.",
                file=sys.stderr,
            )
            return 1

    usage_id = args.usage_id
    if not usage_id:
        print("Error: Specify a usage ID (e.g. usage-0001).", file=sys.stderr)
        return 1
    filepath, records, idx = find_usage_record(op_dir, usage_id)
    if not filepath:
        print(f"Error: Usage record '{usage_id}' not found.", file=sys.stderr)
        return 1

    usage_record = records[idx]

    if usage_record.get("ended_at") is not None and not args.force:
        print(
            f"Error: Usage record '{usage_id}' is already closed (ended_at: {usage_record.get('ended_at')}). Use --force to override.",
            file=sys.stderr,
        )
        return 1

    task_id = usage_record.get("task_id")
    task = None
    task_path = None
    if task_id:
        resolved_task = resolve_task_record(op_dir, task_id)
        if not resolved_task:
            return 1
        _, task_path, task = resolved_task
        preflight_projection(op_dir, task_path, task)

    utc_now = get_current_utc_iso()
    usage_record["ended_at"] = utc_now
    usage_record["outcome"] = args.outcome
    usage_record["cost_estimate_usd"] = args.cost

    raw_payload = ""
    if not sys.stdin.isatty():
        raw_payload = sys.stdin.read().strip()
    elif args.paste:
        print("Paste your final /status or notes (press Ctrl-D to save):")
        try:
            raw_payload = sys.stdin.read().strip()
        except KeyboardInterrupt:
            print("\nAborted.")
            return 1

    if raw_payload:
        usage_record["raw_payload"] = raw_payload

    usage_record["executor"] = get_executor_identity()
    save_yaml(records, filepath)

    if task:
        task["updated_at"] = utc_now
        open_usage_ids = get_open_usage_ids_for_task(op_dir, task_id)
        if args.status:
            task["status"] = args.status
        elif task.get("status") == "running" and not open_usage_ids:
            # Task is no longer running since all sessions for it are closed.
            # Default back to assigned if no explicit status is provided.
            task["status"] = "assigned"
        save_yaml(task, task_path)

    print(f"Successfully closed usage session '{usage_id}'.")
    return 0


def session_list_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    usage_dir = os.path.join(op_dir, "usage")
    if not os.path.isdir(usage_dir):
        print("No sessions found in ledger.")
        return 0

    usage_files = glob.glob(os.path.join(usage_dir, "*.yaml"))

    records = []
    for filepath in usage_files:
        data = load_yaml(filepath) or []
        if isinstance(data, list):
            records.extend(data)

    if not records:
        print("No sessions found in ledger.")
        return 0

    records.sort(key=lambda r: r.get("usage_id", ""))

    filtered_records = []
    for r in records:
        if args.open and r.get("ended_at") is not None:
            continue
        if args.task_id and r.get("task_id") != args.task_id:
            continue
        if args.harness_id and r.get("harness_id") != args.harness_id:
            continue
        filtered_records.append(r)

    if not filtered_records:
        print("No sessions matched the filters.")
        return 0

    print("=" * 110)
    print(
        f"{'USAGE ID':<12} | {'TASK ID':<25} | {'HARNESS':<10} | {'STATUS':<8} | {'STARTED':<25} | {'ENDED'}"
    )
    print("=" * 110)
    for r in filtered_records:
        usage_id = r.get("usage_id", "unknown")
        task_id = r.get("task_id", "unknown")
        harness = r.get("harness_id", "unknown")
        status = "open" if r.get("ended_at") is None else "closed"
        started = r.get("started_at") or "-"
        ended = r.get("ended_at") or "-"
        print(
            f"{usage_id:<12} | {task_id:<25} | {harness:<10} | {status:<8} | {started:<25} | {ended}"
        )
    print("=" * 110)
    return 0


def task_transition_cmd(args) -> int:
    enrollment, op_dir = resolve_operator_context()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    if not enrollment:
        print(
            "Error: task-transition is only supported in enrolled repositories.",
            file=sys.stderr,
        )
        return 1
    ledger_id = enrollment.ledger_id
    socket_path = enrollment.socket_path

    # Resolve task record
    resolved_task = resolve_task_record(op_dir, args.task_id)
    if not resolved_task:
        return 1
    task_id, task_path, task = resolved_task

    # Validate status and claim
    if args.status == "verified":
        if not args.claim:
            print("Error: --claim is required for verified status transition.", file=sys.stderr)
            return 1
        resolved_claim = resolve_claim_record(op_dir, args.claim)
        if not resolved_claim:
            return 1
        claim_path, claim = resolved_claim
        if claim.get("task_id") != task_id:
            print(
                f"Error: Claim '{args.claim}' belongs to task '{claim.get('task_id')}', not '{task_id}'.",
                file=sys.stderr,
            )
            return 1
        claim_id = args.claim
    else:
        if args.claim:
            print("Error: complete transition does not accept claim_id.", file=sys.stderr)
            return 1
        claim_id = None

    # Prepare request
    operation_key = f"op-task-transition-{task_id}-{args.status}"
    try:
        expected = authority_projection.compile_expected(
            op_dir, "task.transition", task_id, claim_id
        )
    except RuntimeError as e:
        print(f"Error: {e}", file=sys.stderr)
        return 1

    request = {
        "action": "commit",
        "ledger_id": ledger_id,
        "operation_key": operation_key,
        "operation": {
            "kind": "task.transition",
            "task_id": task_id,
            "status": args.status,
        },
        "expected": expected,
        "blob": None,
    }
    if claim_id:
        request["operation"]["claim_id"] = claim_id

    # 1. Connect journal, prepare transaction
    conn_journal = authority_projection.ensure_journal(op_dir)
    failure = prepare_journal_transaction(conn_journal, operation_key, request)
    if failure is not None:
        return failure

    # 2. Connect client and send request
    try:
        client = authority_client.AuthorityClient(socket_path)
        res = client.send_request(request)
    except Exception as e:
        print(f"Error: Broker dispatch failed: {e}", file=sys.stderr)
        conn_journal.close()
        return 1

    if not res.get("ok"):
        authority_projection.discard_prepared_transaction(conn_journal, operation_key)
        print(f"Error: Transition rejected by broker: {res.get('error')}", file=sys.stderr)
        conn_journal.close()
        return 1

    # 3. Save receipt
    receipt = res["receipt"]
    authority_projection.commit_transaction(conn_journal, operation_key, receipt)

    # 4. Reconcile
    try:
        authority_projection.reconcile_projections(op_dir, ledger_id, client)
    except Exception as e:
        print(f"Warning: Projection reconciliation failed: {e}", file=sys.stderr)
        conn_journal.close()
        return 0

    conn_journal.close()
    print(f"Successfully transitioned task '{task_id}' to status '{args.status}'.")
    return 0


def authority_reconcile_cmd(args) -> int:
    enrollment, op_dir = resolve_operator_context()
    if not op_dir:
        print("Error: No .operator directory found.", file=sys.stderr)
        return 1

    if not enrollment:
        print(
            "Error: authority-reconcile is only supported in enrolled repositories.",
            file=sys.stderr,
        )
        return 1
    ledger_id = enrollment.ledger_id
    socket_path = enrollment.socket_path

    try:
        client = authority_client.AuthorityClient(socket_path)
        last_digest, seq = authority_projection.reconcile_projections(op_dir, ledger_id, client)
        print(f"Successfully reconciled with broker through commit sequence {seq}.")
        return 0
    except Exception as e:
        print(f"Error: Reconciliation failed: {e}", file=sys.stderr)
        return 1


