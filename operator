def usage_summary_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    usage_dir = os.path.join(op_dir, "usage")
    usage_files = glob.glob(os.path.join(usage_dir, "*.yaml"))

    records = []
    for filepath in usage_files:
        data = load_yaml(filepath) or []
        if isinstance(data, list):
            records.extend(data)

    if not records:
        print("No usage records found in ledger.")
        return 0

    if getattr(args, "offload_audit", False):
        frontier_spend = 0.0
        avoidable_spend = 0.0
        for r in records:
            lane = r.get("lane") or "unknown"
            task_class = r.get("task_class") or "unknown"
            cost = (
                float(r.get("cost_estimate_usd") or 0.0)
                if r.get("cost_estimate_usd") is not None
                else 0.0
            )
            if lane.startswith("frontier_"):
                frontier_spend += cost
                if task_class == "bounded":
                    avoidable_spend += cost
        pct = (avoidable_spend / frontier_spend * 100.0) if frontier_spend > 0 else 0.0
        print(
            f"{pct:.1f}% of frontier spend went to bounded work (avoidable → route to the cheap stack)."
        )
        return 0

    def print_records_summary(recs, title, show_cost):
        total_cost = 0.0
        run_count = 0
        total_tool_calls = 0
        outcome_counts = {}

        task_groups = {}
        harness_groups = {}
        model_groups = {}

        for r in recs:
            cost = (
                float(r.get("cost_estimate_usd") or 0.0)
                if r.get("cost_estimate_usd") is not None
                else 0.0
            )
            task_id = r.get("task_id") or "unknown"
            harness_id = r.get("harness_id") or "unknown"
            model = r.get("model") or "unknown"
            outcome = r.get("outcome") or "unknown"

            activity = r.get("activity", {})
            tool_calls = int(activity.get("tool_calls") or 0)
            turns = int(activity.get("turns") or 0)
            wall_clock = int(activity.get("wall_clock_s") or 0)

            total_cost += cost
            run_count += 1
            total_tool_calls += tool_calls
            outcome_counts[outcome] = outcome_counts.get(outcome, 0) + 1

            if task_id not in task_groups:
                task_groups[task_id] = {
                    "cost": 0.0,
                    "runs": 0,
                    "outcomes": {},
                    "tool_calls": 0,
                }
            task_groups[task_id]["cost"] += cost
            task_groups[task_id]["runs"] += 1
            task_groups[task_id]["outcomes"][outcome] = (
                task_groups[task_id]["outcomes"].get(outcome, 0) + 1
            )
            task_groups[task_id]["tool_calls"] += tool_calls

            if harness_id not in harness_groups:
                harness_groups[harness_id] = {
                    "cost": 0.0,
                    "runs": 0,
                    "outcomes": {},
                    "tool_calls": 0,
                    "turns": 0,
                    "wall_clock_s": 0,
                }
            harness_groups[harness_id]["cost"] += cost
            harness_groups[harness_id]["runs"] += 1
            harness_groups[harness_id]["outcomes"][outcome] = (
                harness_groups[harness_id]["outcomes"].get(outcome, 0) + 1
            )
            harness_groups[harness_id]["tool_calls"] += tool_calls
            harness_groups[harness_id]["turns"] += turns
            harness_groups[harness_id]["wall_clock_s"] += wall_clock

            if model not in model_groups:
                model_groups[model] = {
                    "cost": 0.0,
                    "runs": 0,
                    "outcomes": {},
                    "tool_calls": 0,
                }
            model_groups[model]["cost"] += cost
            model_groups[model]["runs"] += 1
            model_groups[model]["outcomes"][outcome] = (
                model_groups[model]["outcomes"].get(outcome, 0) + 1
            )
            model_groups[model]["tool_calls"] += tool_calls

        print("=" * 80)
        print(title)
        print("=" * 80)
        print(f"Total Runs Captured: {run_count}")
        if show_cost:
            print(f"Total Estimated Cost: ${total_cost:.4f} USD")
        print(f"Total Tool Calls: {total_tool_calls}")
        print("-" * 80)
        print("Outcome Breakdown:")
        for out, cnt in sorted(outcome_counts.items()):
            print(f"  - {out}: {cnt}")
        print("=" * 80)

        if args.by_task:
            print("\n" + "=" * 80)
            print(f"SUMMARY BY TASK ({title})")
            print("=" * 80)
            for tid, data in sorted(task_groups.items()):
                print(f"Task ID:      {tid}")
                print(f"  Runs:       {data['runs']}")
                if show_cost:
                    print(f"  Est. Cost:  ${data['cost']:.4f} USD")
                print(f"  Tool Calls: {data['tool_calls']}")
                outs = ", ".join(
                    f"{k}:{v}" for k, v in sorted(data["outcomes"].items())
                )
                print(f"  Outcomes:   {outs}")
                print("-" * 40)
            print("=" * 80)

        if args.by_harness:
            print("\n" + "=" * 80)
            print(f"SUMMARY BY HARNESS ({title})")
            print("=" * 80)
            for hid, data in sorted(harness_groups.items()):
                print(f"Harness ID:   {hid}")
                print(f"  Runs:       {data['runs']}")
                if show_cost:
                    print(f"  Est. Cost:  ${data['cost']:.4f} USD")
