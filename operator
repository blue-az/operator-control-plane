def task_create_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    if args.assign:
        h_path = os.path.join(op_dir, "harnesses", f"{args.assign}.yaml")
        if not os.path.exists(h_path):
            print(
                f"Error: Assigned harness '{args.assign}' does not exist in registry.",
                file=sys.stderr,
            )
            return 1
    if args.review:
        h_path = os.path.join(op_dir, "harnesses", f"{args.review}.yaml")
        if not os.path.exists(h_path):
            print(
                f"Error: Review harness '{args.review}' does not exist in registry.",
                file=sys.stderr,
            )
            return 1

    objective = args.objective
    task_id = args.task_id
    if not task_id:
        task_id = slugify(objective)[:50]
        if not task_id:
            print(
                "Error: Could not generate task ID from objective. Please provide --id.",
                file=sys.stderr,
            )
            return 1

    if not VALID_TASK_ID.fullmatch(task_id):
        print(
            "Error: Task ID must start with an alphanumeric character and contain only "
            "letters, numbers, '.', '_', or '-'.",
            file=sys.stderr,
        )
        return 1
    task_path = os.path.join(op_dir, "tasks", f"{task_id}.yaml")
    ensure_event_store(op_dir)
    if os.path.exists(task_path) or durable_record_exists(op_dir, "task", task_id):
        print(f"Error: Task '{task_id}' already exists.", file=sys.stderr)
        return 1

    repo = os.path.abspath(args.repo)
    utc_now = get_current_utc_iso()

    task_data = {
        "task_id": task_id,
        "repo": repo,
        "objective": objective,
        "status": "assigned" if args.assign else "new",
        "assigned_harness": args.assign,
        "review_harness": args.review,
        "created_at": utc_now,
        "updated_at": utc_now,
        "operator_decision": None,
        "next_action": None,
        "open_assumptions": args.assumptions,
        "claims": [],
        "evidence": [],
        "executor": get_executor_identity(),
    }

    save_yaml(task_data, task_path)

    config_path = os.path.join(op_dir, "operator.yaml")
    config = load_yaml(config_path) or {}
    config["current_task"] = task_id
    save_yaml(config, config_path)

    os.makedirs(os.path.join(op_dir, "evidence", task_id), exist_ok=True)
    os.makedirs(os.path.join(op_dir, "handoffs", task_id), exist_ok=True)

    print(f"Task '{task_id}' created successfully.")
    print(f"Active task set to '{task_id}'.")
    return 0


def task_show_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    resolved_task = resolve_task_record(op_dir, args.task_id)
    if not resolved_task:
        return 1
    task_id, task_path, task = resolved_task

    print("=" * 80)
    print(f"Task ID:          {task.get('task_id')}")
    print(f"Objective:        {task.get('objective')}")
    print(f"Status:           {task.get('status')}")
    print(f"Repo:             {task.get('repo')}")
    print(f"Assigned Harness: {task.get('assigned_harness') or 'None'}")
    print(f"Review Harness:   {task.get('review_harness') or 'None'}")
    print(f"Created At:       {task.get('created_at')}")
    print(f"Updated At:       {task.get('updated_at')}")
    if task.get("operator_decision"):
        print(f"Operator Dec:     {task.get('operator_decision')}")
    if task.get("next_action"):
        print(f"Next Action:      {task.get('next_action')}")
    print("-" * 80)
    print("Open Assumptions:")
    assumptions = task.get("open_assumptions") or []
    if assumptions:
        for val in assumptions:
            print(f"  - {val}")
    else:
        print("  (None)")
    print("-" * 80)

    print("Claims:")
    claims_list = task.get("claims") or []
    if claims_list:
        for cid in claims_list:
            resolved_claim = resolve_claim_record(op_dir, cid)
            if not resolved_claim:
                print(f"  - {cid} (Record missing)")
                continue
            _, c_data = resolved_claim
            outcome = c_data.get("verification_outcome")
            if not outcome:
                outcome = "verified" if c_data.get("verification_status") else "unverified"
            status_str = str(outcome).upper()
            print(f"  - [{cid}] ({c_data.get('type')}) - {status_str}: {c_data.get('text')}")
            if c_data.get("verdict"):
                print(f"    Verdict: {c_data.get('verdict')}")
    else:
        print("  (None registered)")
    print("-" * 80)

    print("Evidence:")
    ev_list = task.get("evidence") or []
    if ev_list:
        for ev in ev_list:
            print(f"  - {ev}")
    else:
        print("  (None attached)")
    print("-" * 80)

    print("Handoffs:")
    ho_list = task.get("handoffs") or []
    if ho_list:
        for ho in ho_list:
            print(f"  - {ho}")
    else:
        print("  (None captured)")
    print("=" * 80)
    return 0


def prepare_journal_transaction(
    conn_journal, operation_key: str, request: dict, *, evidence_path: str | None = None
) -> int | None:
    """Wrap authority_projection.prepare_transaction; returns an exit code on failure, else None."""
    try:
        authority_projection.prepare_transaction(
            conn_journal, operation_key, request, evidence_path=evidence_path
        )
        return None
    except RuntimeError as e:
        print(
            f"Error: {e}. A prior attempt with this operation key may have already "
            "completed; check current state or run 'operator authority-reconcile' "
            "before retrying.",
            file=sys.stderr,
        )
        conn_journal.close()
        return 1


def claim_add_cmd(args) -> int:
    enrollment, op_dir = resolve_operator_context()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    resolved_task = resolve_task_record(op_dir, args.task_id)
    if not resolved_task:
        return 1
    task_id, task_path, task = resolved_task

    if enrollment:
        ledger_id = enrollment.ledger_id
        socket_path = enrollment.socket_path
        claim_id = get_next_claim_id(op_dir)

        # Prepare request
        operation_key = f"op-claim-add-{claim_id}"
        try:
            expected = authority_projection.compile_expected(
                op_dir, "claim.create", task_id, claim_id
            )
        except RuntimeError as e:
            print(f"Error: {e}", file=sys.stderr)
            return 1

        request = {
            "action": "commit",
            "ledger_id": ledger_id,
            "operation_key": operation_key,
            "operation": {
                "kind": "claim.create",
                "task_id": task_id,
                "claim_id": claim_id,
                "claim_type": args.type,
                "text": args.text,
            },
            "expected": expected,
            "blob": None,
        }
        if args.gate:
            request["operation"]["required_gate"] = args.gate

        conn_journal = authority_projection.ensure_journal(op_dir)
        failure = prepare_journal_transaction(conn_journal, operation_key, request)
        if failure is not None:
            return failure

        try:
            client = authority_client.AuthorityClient(socket_path)
            res = client.send_request(request)
        except Exception as e:
            print(f"Error: Broker dispatch failed: {e}", file=sys.stderr)
            conn_journal.close()
            return 1

        if not res.get("ok"):
            authority_projection.discard_prepared_transaction(conn_journal, operation_key)
            print(f"Error: Claim creation rejected by broker: {res.get('error')}", file=sys.stderr)
            conn_journal.close()
            return 1

        receipt = res["receipt"]
        authority_projection.commit_transaction(conn_journal, operation_key, receipt)

        try:
            authority_projection.reconcile_projections(op_dir, ledger_id, client)
        except Exception as e:
            print(f"Warning: Projection reconciliation failed: {e}", file=sys.stderr)

        conn_journal.close()
        print(f"Registered claim '{claim_id}' on task '{task_id}' via authority broker.")
        return 0

    task_id, task_path, task = resolved_task

    exec_identity = get_executor_identity()
    identity_policy = identity_policy_for_write(op_dir)
    if identity_policy is None:
        return 1
    if identity_policy["mode"] == "enforced" and not require_executor_role(
        identity_policy, exec_identity, "builder", "create claim"
    ):
        return 1

    preflight_projection(op_dir, task_path, task)

    claim_id = get_next_claim_id(op_dir)
    made_by = args.by if args.by else task.get("assigned_harness") or "operator"
    utc_now = get_current_utc_iso()

    claim_data = {
        "claim_id": claim_id,
        "task_id": task_id,
        "type": args.type,
        "text": args.text,
        "made_by": made_by,
        "made_at": utc_now,
        "verification_status": False,
        "verdict": None,
        "verified_by": None,
        "evidence_refs": [],
        "required_gate": args.gate,
        "supervision_layer": args.layer,
        "executor": dict(exec_identity),
        "author_executor": dict(exec_identity),
    }

    claim_path = os.path.join(op_dir, "claims", f"{claim_id}.yaml")
    save_yaml(claim_data, claim_path)

    if args.type == "supervision_credit" and not args.layer:
        print(
            "Warning: supervision_credit claim has no --layer; doctor will flag "
            "it as an ambiguous credit (FR-12).",
            file=sys.stderr,
        )

    task["claims"] = task.get("claims") or []
    if claim_id not in task["claims"]:
        task["claims"].append(claim_id)
    task["updated_at"] = utc_now
    save_yaml(task, task_path)

    print(f"Registered claim '{claim_id}' on task '{task_id}'.")
    return 0


def evidence_attach_cmd(args) -> int:
    enrollment, op_dir = resolve_operator_context()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    resolved_task = resolve_task_record(op_dir, args.task_id)
    if not resolved_task:
        return 1
    task_id, task_path, task = resolved_task

    if enrollment:
        ledger_id = enrollment.ledger_id
        socket_path = enrollment.socket_path

        # Enrolled evidence requires claim
        if not args.claim:
            print(
                "Error: --claim is required for evidence-attach in enrolled repositories.",
                file=sys.stderr,
            )
            return 1

        resolved_claim = resolve_claim_record(op_dir, args.claim)
        if not resolved_claim:
            return 1
        claim_path, claim = resolved_claim
        if claim.get("task_id") != task_id:
            print(
                f"Error: Claim '{args.claim}' belongs to task '{claim.get('task_id')}', not '{task_id}'.",
                file=sys.stderr,
            )
            return 1

        # Get path_or_url
        original_locator = args.path_or_url
        if not os.path.exists(original_locator) or not os.path.isfile(original_locator):
            print(
                f"Error: Evidence path does not exist or is not a file: {original_locator}",
                file=sys.stderr,
            )
            return 1

        # Calculate file size and sha256
        size_bytes = os.path.getsize(original_locator)
        h = hashlib.sha256()
        with open(original_locator, "rb") as f:
            while True:
                chunk = f.read(65536)
                if not chunk:
                    break
                h.update(chunk)
        file_hash = h.hexdigest()

        if args.hash:
            try:
                expected_hash = normalize_sha256(args.hash)
                if expected_hash != file_hash:
                    print(
                        f"Error: SHA-256 hash mismatch. Expected: {expected_hash}, Actual: {file_hash}",
                        file=sys.stderr,
                    )
                    return 1
            except Exception as e:
                print(f"Error: Invalid --hash: {e}", file=sys.stderr)
                return 1

        # Generate evidence_id
        evidence_id = get_next_evidence_id(op_dir, task_id)

        # Prepare operation
        kind = "evidence.attach_status" if args.status else "evidence.attach_draft"
        operation = {
            "kind": kind,
            "task_id": task_id,
            "claim_id": args.claim,
            "evidence_id": evidence_id,
            "evidence_type": args.type,
        }
        if args.status:
            operation["verification_status"] = args.status

        try:
            expected = authority_projection.compile_expected(
                op_dir, kind, task_id, args.claim, evidence_id
            )
        except RuntimeError as e:
            print(f"Error: {e}", file=sys.stderr)
            return 1

        operation_key = f"op-evidence-attach-{evidence_id}"
        request = {
            "action": "commit",
            "ledger_id": ledger_id,
            "operation_key": operation_key,
            "operation": operation,
            "expected": expected,
            "blob": {
                "sha256": file_hash,
                "size_bytes": size_bytes,
            },
        }

        conn_journal = authority_projection.ensure_journal(op_dir)
        failure = prepare_journal_transaction(
            conn_journal, operation_key, request, evidence_path=original_locator
        )
        if failure is not None:
            return failure

        try:
            client = authority_client.AuthorityClient(socket_path)
            res = client.send_request(request, evidence_path=original_locator)
        except Exception as e:
            print(f"Error: Broker dispatch failed: {e}", file=sys.stderr)
            conn_journal.close()
            return 1

        if not res.get("ok"):
            authority_projection.discard_prepared_transaction(conn_journal, operation_key)
            print(
                f"Error: Evidence attachment rejected by broker: {res.get('error')}",
                file=sys.stderr,
            )
            conn_journal.close()
            return 1

        receipt = res["receipt"]
        authority_projection.commit_transaction(conn_journal, operation_key, receipt)

        try:
            authority_projection.reconcile_projections(op_dir, ledger_id, client)
        except Exception as e:
            print(f"Warning: Projection reconciliation failed: {e}", file=sys.stderr)

        conn_journal.close()
        print(f"Registered evidence '{evidence_id}' on task '{task_id}' via authority broker.")
        return 0

    claim_id = args.claim
    claim = None
    exec_identity = get_executor_identity()
    identity_policy = identity_policy_for_write(op_dir)
    if identity_policy is None:
        return 1
    verified_by_value = args.verified_by
    verification_authority = None

    if claim_id:
        resolved_claim = resolve_claim_record(op_dir, claim_id)
        if not resolved_claim:
            return 1
        claim_path, claim = resolved_claim
        if claim.get("task_id") != task_id:
            print(
                f"Error: Claim '{claim_id}' belongs to task '{claim.get('task_id')}', not "
                f"'{task_id}'.",
                file=sys.stderr,
            )
            return 1

    # A status changes claim trust state; reject a bare write so it cannot silently succeed and drop.
    if args.status and not claim:
        print(
            "Error: --status requires --claim. A status changes trust state on a claim; bare evidence "
            "write cannot carry one (the status would be silently dropped).",
            file=sys.stderr,
        )
        return 1

    if args.status:
        if not getattr(args, "verified_by", None):
            print(
                "Error: --verified-by is required when setting --status (the verifier must identify themselves).",
                file=sys.stderr,
            )
            return 1

        if identity_policy["mode"] == "enforced":
            actual_verifier = require_executor_role(
                identity_policy, exec_identity, "verifier", "record verification"
            )
            if not actual_verifier:
                return 1
            if args.verified_by != actual_verifier["name"]:
                print(
                    f"Error: --verified-by '{args.verified_by}' does not match the executing "
                    f"identity '{actual_verifier['name']}'",
                    file=sys.stderr,
                )
                return 1

            author_executor = claim.get("author_executor")
            author_uid = author_executor.get("uid") if isinstance(author_executor, dict) else None
            if not isinstance(author_uid, int) or isinstance(author_uid, bool) or author_uid < 0:
                print(
                    "Error: refusing to record verification: claim has no valid author UID; "
                    "legacy authorship cannot be inferred",
                    file=sys.stderr,
                )
                return 1
            if author_uid == exec_identity["uid"]:
                print(
                    "Error: refusing to record verification: verifier UID must differ from the "
                    f"claim author UID ({author_uid})",
                    file=sys.stderr,
                )
                return 1

            verified_by_value = actual_verifier["name"]
            verification_authority = "uid_isolated"
        else:
            verified_by_value = args.verified_by
            verification_authority = "advisory"
    elif identity_policy["mode"] == "enforced" and not require_executor_role(
        identity_policy, exec_identity, "builder", "attach evidence"
    ):
        return 1

    expected_hash = None
    if args.hash is not None:
        try:
            expected_hash = normalize_sha256(args.hash)
        except EvidenceFingerprintError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1

    original_locator = args.path_or_url
    path_or_url = original_locator
    source_fingerprint = None
    source_path = None
    source_kind = None
    fingerprint = None
    source = None
    provenance = "url_or_external"

    if os.path.exists(original_locator):
        if not os.path.isfile(original_locator):
            print(
                f"Error: Evidence path is not a regular file: {original_locator}",
                file=sys.stderr,
            )
            return 1
        source_path = os.path.abspath(original_locator)
        try:
            source_fingerprint = fingerprint_regular_file(source_path)
        except EvidenceFingerprintError as exc:
            print(f"Error: {exc}", file=sys.stderr)
            return 1
        if expected_hash and expected_hash != source_fingerprint["value"]:
            print(
                "Error: Supplied SHA-256 does not match local evidence bytes "
                f"(expected {expected_hash}, got {source_fingerprint['value']})",
                file=sys.stderr,
            )
            return 1
    else:
        scheme_match = re.match(r"^([A-Za-z][A-Za-z0-9+.-]*):", original_locator)
        scheme = scheme_match.group(1).lower() if scheme_match else None
        if scheme in {"http", "https"}:
            source_kind = "remote_url"
        elif scheme and scheme != "file":
            source_kind = "external_reference"
        else:
            print(f"Error: Local evidence file does not exist: {original_locator}", file=sys.stderr)
            return 1

    preflight_projection(op_dir, task_path, task)
    if claim:
        preflight_projection(op_dir, claim_path, claim)

    evidence_id = get_next_evidence_id(op_dir, task_id)

    if source_path:

        dest_dir = os.path.join(op_dir, "evidence", task_id)
        os.makedirs(dest_dir, exist_ok=True)
        ext = os.path.splitext(source_path)[1]
        artifact_name = (
            f"artifact-{evidence_id}{ext}" if ext in {".yaml", ".yml"} else f"{evidence_id}{ext}"
        )
        dest_path = os.path.join(dest_dir, artifact_name)
        if os.path.lexists(dest_path):
            print(
                f"Error: Evidence artifact destination already exists: {dest_path}", file=sys.stderr
            )
            return 1

        temp_fd, temp_path = tempfile.mkstemp(prefix=f".{artifact_name}.", dir=dest_dir)
        os.close(temp_fd)
        try:
            shutil.copy2(source_path, temp_path)
            fingerprint = fingerprint_regular_file(temp_path)
            if fingerprint["value"] != source_fingerprint["value"]:
                raise EvidenceFingerprintError(
                    f"Evidence file changed while being persisted: {source_path}"
                )
            os.link(temp_path, dest_path)
        except (OSError, EvidenceFingerprintError) as exc:
            print(f"Error: Could not persist evidence file '{source_path}': {exc}", file=sys.stderr)
            return 1
        finally:
            try:
                os.unlink(temp_path)
            except FileNotFoundError:
                pass

        path_or_url = os.path.abspath(dest_path)
        provenance = "local_file"
        source = {
            "kind": "local_file",
            "locator": source_path,
            "fingerprint": source_fingerprint,
        }
    else:
        source = {"kind": source_kind, "locator": original_locator}
        if expected_hash:
            fingerprint = {
                "algorithm": "sha256",
                "value": expected_hash,
                "size_bytes": None,
                "mtime_ns": None,
            }

    file_hash = fingerprint["value"] if fingerprint else None
    made_by = args.by if args.by else task.get("assigned_harness") or "operator"
    utc_now = get_current_utc_iso()

    evidence_data = {
        "evidence_id": evidence_id,
        "task_id": task_id,
        "claim_id": claim_id,
        "path_or_url": path_or_url,
        "evidence_type": args.type,
        "produced_by": made_by,
        "produced_at": utc_now,
        "provenance": provenance,
        "hash": file_hash,
        "fingerprint": fingerprint,
        "source": source,
        "verification_command": args.verify_cmd,
        "notes": args.notes,
        "executor": exec_identity,
    }

    ev_path = os.path.join(op_dir, "evidence", task_id, f"{evidence_id}.yaml")
    save_yaml(evidence_data, ev_path)

    task["evidence"] = task.get("evidence") or []
    if path_or_url not in task["evidence"]:
        task["evidence"].append(path_or_url)
    task["updated_at"] = utc_now
    save_yaml(task, task_path)

    if claim:
        claim["evidence_refs"] = claim.get("evidence_refs") or []
        ref_str = f"evidence/{task_id}/{evidence_id}.yaml"
        if ref_str not in claim["evidence_refs"]:
            claim["evidence_refs"].append(ref_str)

        if args.status:
            claim["verified_by"] = verified_by_value
            claim["verification_outcome"] = args.status
            claim["verification_executor"] = dict(exec_identity)
            claim["verification_authority"] = verification_authority
            claim["verification_mode"] = identity_policy["mode"]
            if args.status == "verified":
                claim["verification_status"] = True
            else:
                claim["verification_status"] = False

            claim["executor"] = exec_identity

        if args.verdict:
            claim["verdict"] = args.verdict

        save_yaml(claim, claim_path)

        if args.status == "quarantined":
            task["status"] = "quarantined"
            save_yaml(task, task_path)
        elif args.status == "verified" and task["status"] not in [
            "quarantined",
            "complete",
        ]:
            task["status"] = "verified"
            save_yaml(task, task_path)

    print(f"Attached evidence '{evidence_id}' to task '{task_id}'.")
    if claim_id:
        print(
            f"Associated with claim '{claim_id}' (Verification status: {claim.get('verification_status')})."
        )
    return 0


def usage_add_cmd(args) -> int:
