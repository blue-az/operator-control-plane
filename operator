def doctor_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    tasks_dir = os.path.join(op_dir, "tasks")
    task_files = glob.glob(os.path.join(tasks_dir, "*.yaml"))

    issues = []
    infos = []

    # Load identity map
    identity_path = os.path.join(op_dir, "identity.yaml")
    identity_map = {}
    mode = "single_user"
    if os.path.exists(identity_path):
        id_data = load_yaml(identity_path) or {}
        mode = id_data.get("mode", "single_user")
        identity_map = id_data.get("uids", {})

    def check_executor_block(item, source_name):
        executor = item.get("executor")
        if not executor:
            return
        if executor.get("test_override_active"):
            issues.append(
                f"[Error] {source_name} contains write made with test-override active"
            )
        if executor.get("test_override_unauthorized"):
            issues.append(
                f"[Error] {source_name} contains write with unauthorized test-override attempt"
            )

    for tf in task_files:
        task = load_yaml(tf)
        if not task:
            continue

        task_id = task.get("task_id", os.path.splitext(os.path.basename(tf))[0])
        check_executor_block(task, f"Task {task_id}")
        task_status = task.get("status")

        claims_list = task.get("claims") or []
        quarantined_claims = []
        verified_claims = []
        for cid in claims_list:
            c_path = os.path.join(op_dir, "claims", f"{cid}.yaml")
            if not os.path.exists(c_path):
                issues.append(f"[Error] Task {task_id} references missing claim: {cid}")
                continue

            c_data = load_yaml(c_path)
            if not c_data:
                issues.append(f"[Error] Claim {cid} could not be loaded.")
                continue

            check_executor_block(c_data, f"Claim {cid}")

            if not c_data.get("required_gate"):
                issues.append(
                    f"[Warning] Claim {cid} ('{c_data.get('text')}') has no required_gate defined."
                )

            if c_data.get("type") == "supervision_credit" and not c_data.get(
                "supervision_layer"
            ):
                issues.append(
                    f"[Warning] Claim {cid} is a supervision_credit with no named layer (ambiguous credit; FR-12)."
                )

            evidence_refs = c_data.get("evidence_refs") or []
            if c_data.get("verification_status") and not evidence_refs:
                issues.append(
                    f"[Error] Claim {cid} is marked verified but has no evidence references."
                )

            for ev_ref in evidence_refs:
                ev_ref_path = os.path.join(op_dir, ev_ref)
                if not os.path.exists(ev_ref_path):
                    issues.append(
                        f"[Error] Claim {cid} evidence reference points to missing file: {ev_ref}"
                    )
                else:
                    ev_ref_data = load_yaml(ev_ref_path)
                    if ev_ref_data:
                        check_executor_block(ev_ref_data, f"Evidence file {ev_ref}")
                        if ev_ref_data.get(
                            "provenance"
                        ) == "local_file" and not ev_ref_data.get("hash"):
                            issues.append(
                                f"[Warning] Claim {cid} evidence reference has no stored hash: {ev_ref}"
                            )

            outcome = c_data.get("verification_outcome")
            if outcome == "quarantined":
                quarantined_claims.append(cid)
            elif c_data.get("verification_status") or outcome == "verified":
                verified_claims.append(cid)

            made = c_data.get("made_by")
            vby = c_data.get("verified_by")
            verified = (outcome == "verified") or bool(
                c_data.get("verification_status")
            )
            review = task.get("review_harness")

            if verified:
                if vby == made:
                    issues.append(
                        f"[Error] claim {cid} is self-verified by '{made}' (maker cannot verify own claim)"
                    )
                elif vby and review and vby != review:
                    issues.append(
                        f"[Warning] claim {cid} verified by '{vby}', not the task's review harness '{review}'"
                    )

                # Executor verification checks
                executor = c_data.get("executor")
                if not vby or not executor:
                    infos.append(
                        f"[Info] Claim {cid} has unknown verifier (legacy claim)"
                    )
                else:
                    exec_uid = executor.get("uid")
                    expected_verifier = identity_map.get(exec_uid)
                    if expected_verifier is None:
                        expected_verifier = identity_map.get(str(exec_uid))

                    if mode == "enforced":
                        if not expected_verifier:
                            issues.append(
                                f"[Error] claim {cid} verified by unknown UID {exec_uid}"
                            )
                        elif vby != expected_verifier:
                            issues.append(
                                f"[Error] claim {cid} verification identity mismatch (possible impersonation): verified_by is '{vby}', but executor maps to '{expected_verifier}' (uid {exec_uid})"
                            )
                    else:
                        # mode is single_user or missing
                        infos.append(
                            f"[Warning] claim {cid} verification is NOT identity-enforced (single-user mode); see EXECUTOR_IDENTITY_SPEC §5"
                        )
                        # Enforcement-downgrade detection (warn-only, exit unchanged):
                        # the identity map IS configured and this claim's executor maps to a
                        # known identity, yet verified_by does not match it. enforced mode would
                        # reject this as impersonation; single_user silently accepts it. Surface
                        # the relaxation so a config flip (enforced -> single_user) is not silent.
                        if expected_verifier and vby != expected_verifier:
                            infos.append(
                                f"[Warning] claim {cid} would be REJECTED under enforced mode: verified_by '{vby}' != identity '{expected_verifier}' for uid {exec_uid}; enforcement appears relaxed to single_user"
                            )

        if task_status in ["verified", "complete"] and quarantined_claims:
            issues.append(
                f"[Error] Task {task_id} status is '{task_status}' while claims are quarantined: {', '.join(quarantined_claims)}"
            )

        if task_status == "quarantined" and verified_claims:
            issues.append(
                f"[Error] Task {task_id} is quarantined while claims are still marked verified: {', '.join(verified_claims)}"
            )

        ho_list = task.get("handoffs") or []
        for ho_ref in ho_list:
            ho_path = os.path.join(op_dir, ho_ref)
            if not os.path.exists(ho_path):
                issues.append(
                    f"[Error] Task {task_id} handoff reference points to missing file: {ho_ref}"
                )
            else:
                ho_data = load_yaml(ho_path)
                if ho_data:
                    ho_id = ho_data.get("handoff_id")
                    check_executor_block(ho_data, f"Handoff {ho_id} for task {task_id}")

        if ho_list:
            latest_ho_ref = ho_list[-1]
            latest_ho_path = os.path.join(op_dir, latest_ho_ref)
            if os.path.exists(latest_ho_path):
                latest_ho = load_yaml(latest_ho_path)
                if latest_ho:
                    ho_next = latest_ho.get("next_action")
                    task_next = task.get("next_action")
                    if (
                        task_status not in ["verified", "complete"]
                        and ho_next
                        and ho_next != task_next
                    ):
                        issues.append(
                            f"[Warning] Task {task_id} next_action differs from the latest handoff recommended next action. Task: '{task_next}', Handoff: '{ho_next}'"
                        )

        ev_dir = os.path.join(op_dir, "evidence", task_id)
        if os.path.isdir(ev_dir):
            ev_files = glob.glob(os.path.join(ev_dir, "evidence-*.yaml"))
            for ef in ev_files:
                ev_data = load_yaml(ef)
                if not ev_data:
                    continue
                ev_id = ev_data.get("evidence_id")
                check_executor_block(ev_data, f"Evidence {ev_id} for task {task_id}")
                path_or_url = ev_data.get("path_or_url")
                provenance = ev_data.get("provenance")
                stored_hash = ev_data.get("hash")

                if provenance in [
                    "local_file",
                    "living_document",
                    "structural_verification",
                ]:
                    if not os.path.exists(path_or_url):
                        issues.append(
                            f"[Warning] Evidence {ev_id} local file is missing: {path_or_url}"
                        )
                    elif provenance == "local_file":
                        curr_hash = calculate_file_hash(path_or_url)
                        if curr_hash and curr_hash != stored_hash:
                            issues.append(
                                f"[Error] Evidence {ev_id} local file hash has changed (expected {stored_hash}, got {curr_hash}). File: {path_or_url}"
                            )

        if args.audit and task_status == "verified":
            # Check for independent supervisor_verdict.md (Phase 3.2)
            # Assumption: run directories are under docs/domain_runs/DBB-001a/
            # We'll try to find a directory matching task_id (or similar)
            pass

    usage_by_task = {}
    pricing_table = load_pricing_table(op_dir)

    def check_divergence(val_manual, val_auto):
        try:
            m = float(val_manual)
            a = float(val_auto)
            if m == a:
                return False
            if a == 0 or m == 0:
                return True
            return m > 2 * a or a > 2 * m
        except Exception:
            return False

    usage_dir = os.path.join(op_dir, "usage")
    if os.path.isdir(usage_dir):
        for usage_path in glob.glob(os.path.join(usage_dir, "*.yaml")):
            records = load_yaml(usage_path) or []
            for rec in records:
                task_id = rec.get("task_id")
                usage_id = rec.get("usage_id", "unknown")
                check_executor_block(rec, f"Usage record {usage_id}")
                if task_id and rec.get("ended_at") is None:
                    usage_by_task.setdefault(task_id, []).append(usage_id)
                    infos.append(
                        f"[Info] Task {task_id} has open usage session: {usage_id}"
                    )

                if (
                    rec.get("lane") == "frontier_driver"
                    and rec.get("task_class") == "bounded"
                ):
                    infos.append(
                        f"[Info] Session {usage_id} is an offload candidate (tagged frontier_driver + bounded)."
                    )

                harness_id = rec.get("harness_id")
                metering = rec.get("metering")
                if not metering:
                    metering = "activity" if harness_id == "gemini-agy" else "tokens"

                if metering == "tokens" and rec.get("cost_estimate_usd") is None:
                    model = rec.get("model")
                    if model not in pricing_table:
                        issues.append(f"[Warning] price table missing model {model}")

                source_ref = rec.get("source_session_ref")
                if source_ref and not os.path.exists(source_ref):
                    issues.append(
                        f"[Warning] Usage record {usage_id} source session log file is missing: {source_ref}"
                    )

                cost_estimate = rec.get("cost_estimate_usd")
                field_sources = rec.get("field_sources", {})
                if metering == "activity" and cost_estimate is not None:
                    if field_sources.get("cost_estimate_usd") == "auto":
                        issues.append(
                            f"[Error] Usage record {usage_id} is activity-metered but has auto-calculated cost."
                        )

                auto_vals = rec.get("auto_values", {})

                for field in [
                    "tokens_in",
                    "tokens_out",
                    "tokens_cache_read",
                    "tokens_cache_write",
                    "cost_estimate_usd",
                ]:
                    if field_sources.get(field) == "manual" and field in auto_vals:
                        m_val = rec.get(field)
                        a_val = auto_vals[field]
                        if m_val is not None and a_val is not None:
                            if check_divergence(m_val, a_val):
                                issues.append(
                                    f"[Warning] manual/auto divergence on {field}"
                                )

                activity = rec.get("activity", {})
                for field in ["tool_calls", "turns", "wall_clock_s", "quota_events"]:
                    if field_sources.get(field) == "manual" and field in auto_vals:
                        m_val = activity.get(field)
                        a_val = auto_vals[field]
                        if m_val is not None and a_val is not None:
                            if check_divergence(m_val, a_val):
                                issues.append(
                                    f"[Warning] manual/auto divergence on {field}"
                                )
    infos.sort()

    for tf in task_files:
        task = load_yaml(tf)
        if not task:
            continue
        task_id = task.get("task_id", os.path.splitext(os.path.basename(tf))[0])
        status = task.get("status")
        open_usage_ids = usage_by_task.get(task_id, [])
        if status == "running" and not open_usage_ids:
            issues.append(
                f"[Warning] Task {task_id} is running but has no open usage session."
            )
        if status != "running" and open_usage_ids:
            issues.append(
                f"[Error] Task {task_id} is '{status}' but has open usage sessions: {', '.join(open_usage_ids)}"
            )
        if len(open_usage_ids) > 1:
            issues.append(
                f"[Warning] Task {task_id} has multiple open usage sessions: {', '.join(open_usage_ids)}"
            )

    print("=" * 80)
    print("OPERATOR DOCTOR - LEDGER CONSISTENCY REPORT")
    print("=" * 80)
    all_msgs = infos + issues
    if all_msgs:
        for msg in all_msgs:
            print(msg)
        print("-" * 80)

    if issues:
        print(f"Total consistency issues found: {len(issues)}")
        return 1
    else:
        print("All records consistent. No issues found.")
        print("=" * 80)
        return 0


def verify_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print("Error: No .operator directory found.", file=sys.stderr)
        return 1

    run_dir = Path(args.run_dir).resolve()
    if not run_dir.is_dir():
        print(f"Error: {run_dir} is not a directory.", file=sys.stderr)
        return 1

    verdict_path = run_dir / "candidate_verdict.md"
    if not verdict_path.exists():
        print(f"Error: candidate_verdict.md missing in {run_dir}", file=sys.stderr)
        return 1

    print(f"Verifying run directory: {run_dir}")

    issues = []

    # Load candidate verdict
    try:
        with open(verdict_path, "r") as f:
            content = f.read()
            # Simple YAML extraction from markdown
            match = re.search(r"```yaml\n(.*?)\n```", content, re.DOTALL)
            if match:
                verdict_data = yaml.safe_load(match.group(1))
            else:
                # Try parsing raw if no code block
                verdict_data = yaml.safe_load(content)
    except Exception as e:
        print(f"Error parsing candidate_verdict.md: {e}", file=sys.stderr)
        return 1

    if not verdict_data:
        print("Error: Empty or invalid candidate_verdict.md", file=sys.stderr)
        return 1

    # Normalize structure (candidate_verdict might be nested or flat)
    v_info = verdict_data.get("candidate_verdict", verdict_data)

    # 1. Recalculate artifact hashes (Phase 3.1.1)
    stored_hashes = v_info.get("distinct_tools_hashes", {})
    if stored_hashes:
        for variation, stored_hash in stored_hashes.items():
            tools_path = (
                run_dir / "saved_implementation" / "variations" / variation / "tools.py"
            )
            if tools_path.exists():
                curr_hash = hashlib.md5(tools_path.read_bytes()).hexdigest()
                if curr_hash != stored_hash:
                    issues.append(
                        f"[Error] Hash mismatch for {variation}: stored {stored_hash}, recalculated {curr_hash}"
                    )
            else:
                issues.append(
                    f"[Warning] Referenced variation {variation} missing on disk at {tools_path}"
                )

    # 2. Verify verified_by != made_by (Phase 3.1.2)
    handoff_id = v_info.get("handoff_id")
    if handoff_id:
        # We need to find the claim in the operator ledger
        # This is a bit complex as we need to scan tasks
        found_claim = False
        tasks_dir = os.path.join(op_dir, "tasks")
        for tf in glob.glob(os.path.join(tasks_dir, "*.yaml")):
            task = load_yaml(tf)
            if not task:
                continue
            for cid in task.get("claims", []):
                c_path = os.path.join(op_dir, "claims", f"{cid}.yaml")
                if os.path.exists(c_path):
                    c_data = load_yaml(c_path)
                    if (
                        c_data
                        and c_data.get("text")
                        and handoff_id in c_data.get("text", "")
                    ):
                        found_claim = True
                        made = c_data.get("made_by")
                        vby = c_data.get("verified_by")
                        if vby and made and vby == made:
                            issues.append(
                                f"[Error] Claim for {handoff_id} is self-verified by '{made}'"
                            )
        if not found_claim:
            # We skip if handoff isn't in ledger yet, but warn
            pass

    # 3. Check for Evidence Drift (Phase 3.1.3)
    # Check AGENT_HANDOFF_STATUS.md against current disk state
    status_path = Path(op_dir).parent / "AGENT_HANDOFF_STATUS.md"
    if status_path.exists():
        status_content = status_path.read_text()
        # Look for the row matching implementation_path
        impl_path = v_info.get("implementation_path")
        if impl_path:
            # Look for | Implementation Path | ... | hash | ...
            # Regex for table row
            pattern = rf"\|\s*{re.escape(impl_path)}.*\|\s*([a-f0-9]+)\s*\|"
            match = re.search(pattern, status_content, re.IGNORECASE)
            if match:
                status_hash = match.group(1)
                # Check against variation_1/tools.py hash (typical for DBB-001a)
                t1_path = (
                    run_dir
                    / "saved_implementation"
                    / "variations"
                    / "variation_1"
                    / "tools.py"
                )
                if t1_path.exists():
                    curr_t1_hash = hashlib.md5(t1_path.read_bytes()).hexdigest()[:8]
                    if curr_t1_hash != status_hash:
                        issues.append(
                            f"[Error] Evidence Drift: AGENT_HANDOFF_STATUS.md reports {status_hash}, but disk implementation hash is {curr_t1_hash}"
                        )

    if issues:
        print("--- VERIFICATION ISSUES FOUND ---")
        for msg in issues:
            print(msg)
        return 1
    else:
        print("All artifact hashes and metadata verified successfully.")
        return 0


def task_list_cmd(args) -> int:
    op_dir = find_operator_dir()
    if not op_dir:
        print(
            "Error: No .operator directory found. Run 'operator init' first.",
            file=sys.stderr,
        )
        return 1

    tasks_dir = os.path.join(op_dir, "tasks")
    task_files = glob.glob(os.path.join(tasks_dir, "*.yaml"))

    if not task_files:
        print("No tasks found in ledger.")
        return 0

    tasks_data = []
    for tf in sorted(task_files):
        task = load_yaml(tf)
        if not task:
            continue

        task_id = task.get("task_id")
        status = task.get("status")
        assign = task.get("assigned_harness") or "None"
        review = task.get("review_harness") or "None"
        next_act = task.get("next_action") or "None"

        claims_list = task.get("claims") or []
        verified_cnt = 0
        quarantined_cnt = 0
        open_cnt = 0

        for cid in claims_list:
            c_path = os.path.join(op_dir, "claims", f"{cid}.yaml")
            if os.path.exists(c_path):
                c_data = load_yaml(c_path)
                if c_data:
                    outcome = c_data.get("verification_outcome")
                    if outcome == "quarantined":
                        quarantined_cnt += 1
                    elif c_data.get("verification_status") or outcome == "verified":
                        verified_cnt += 1
                    else:
                        open_cnt += 1
            else:
                open_cnt += 1

        claims_summary = f"V:{verified_cnt} Q:{quarantined_cnt} O:{open_cnt}"

        tasks_data.append(
            {
                "task_id": task_id,
                "status": status,
                "assign": assign,
                "review": review,
                "claims": claims_summary,
                "next_action": next_act,
            }
        )

    print("=" * 100)
    print(
        f"{'TASK ID':<25} | {'STATUS':<12} | {'ASSIGNED':<10} | {'REVIEWER':<10} | {'CLAIMS':<10} | {'LATEST NEXT ACTION'}"
    )
    print("=" * 100)
    for td in tasks_data:
        na = td["next_action"]
        if len(na) > 30:
            na = na[:27] + "..."
        print(
            f"{td['task_id']:<25} | {td['status']:<12} | {td['assign']:<10} | {td['review']:<10} | {td['claims']:<10} | {na}"
        )
    print("=" * 100)
    return 0


